<Application x:Class="PopClip.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:PopClip.App"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 全局引入 WPF-UI（Fluent 风格 / Mica 标题栏 / NumberBox / InfoBar 等社区控件库），
                 让设置窗口里的原生控件自动获得 Fluent 样式。Theme.xaml/SettingsTheme.xaml 在其后合并，
                 既保留我们的页面级 token，也避免覆盖 FloatingToolbar 内显式 Style 的按钮。 -->
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="UI/Resources/Theme.xaml" />
                <ResourceDictionary Source="UI/Resources/SettingsTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
