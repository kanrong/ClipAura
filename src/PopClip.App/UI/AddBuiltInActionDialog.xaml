<ui:FluentWindow x:Class="PopClip.App.UI.AddBuiltInActionDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:PopClip.App.UI"
                 Title="添加内置动作"
                 Icon="pack://application:,,,/Assets/AppIcon.ico"
                 Width="560" Height="640"
                 MinWidth="480" MinHeight="420"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 Foreground="{DynamicResource Settings.Foreground}"
                 FontFamily="{DynamicResource Settings.FontFamily}"
                 UseLayoutRounding="True"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <local:IconKeyToMaterialDesignKindConverter x:Key="MaterialIconConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="添加内置动作" />

        <StackPanel Grid.Row="1" Margin="18,12,18,8">
            <TextBlock Text="选择要加入浮窗的内置动作"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource Settings.Foreground}" />
            <TextBlock x:Name="EmptyHintText"
                       Text="所有内置动作都已添加，可以直接在主列表里启用/调整顺序。"
                       FontSize="12"
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource Settings.SubtleForeground}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="HintText"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Foreground="{DynamicResource Settings.SubtleForeground}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      Margin="10,0,10,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="GroupsList" ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:BuiltInPickGroup}">
                        <Border Margin="8,4,8,12"
                                Padding="14,10,14,6"
                                Background="{DynamicResource Settings.Card.SubtleBackground}"
                                BorderBrush="{DynamicResource Settings.Stroke}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Settings.Foreground}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:BuiltInPickItem}">
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          VerticalAlignment="Top"
                                                          Margin="0,4,8,0" />
                                                <Grid Grid.Column="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <iconPacks:PackIconMaterialDesign Grid.Column="0"
                                                                                       Kind="{Binding IconKey, Converter={StaticResource MaterialIconConv}}"
                                                                                       Width="16" Height="16"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,2,0,0"
                                                                                       Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource Settings.Foreground}" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Margin="0,1,0,4"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource Settings.SubtleForeground}"
                                                                   Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3"
                Background="{DynamicResource Settings.Card.SubtleBackground}"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="0,1,0,0"
                Padding="18,10,18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0"
                           Appearance="Transparent"
                           Content="全选 / 反选"
                           Click="OnToggleSelectAll" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           x:Name="CountText"
                           Foreground="{DynamicResource Settings.SubtleForeground}"
                           FontSize="12" />
                <ui:Button Grid.Column="2"
                           Appearance="Secondary"
                           Content="取消"
                           Margin="0,0,8,0"
                           Click="OnCancel" />
                <ui:Button Grid.Column="3"
                           x:Name="ConfirmButton"
                           Appearance="Primary"
                           Content="添加"
                           IsDefault="True"
                           Click="OnConfirm" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
