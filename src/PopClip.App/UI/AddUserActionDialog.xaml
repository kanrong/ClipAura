<ui:FluentWindow x:Class="PopClip.App.UI.AddUserActionDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:PopClip.App.UI"
                 Title="添加用户动作"
                 Width="640"
                 Height="600"
                 MinWidth="520"
                 MinHeight="420"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 Foreground="{DynamicResource Settings.Foreground}"
                 FontFamily="{DynamicResource Settings.FontFamily}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Background="{DynamicResource Settings.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     x:Name="TitleBar"
                     Title="添加用户动作"
                     Style="{StaticResource Settings.CompactTitleBar}"
                     ShowMaximize="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Add24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <TextBlock Grid.Row="1"
                   Margin="20,8,20,12"
                   FontSize="12"
                   Foreground="{DynamicResource Settings.SubtleForeground}"
                   TextWrapping="Wrap"
                   Text="用户动作可以自由编辑、重复创建。要添加复制 / 翻译 / AI 解释 等系统已经提供的动作，请使用顶部的&quot;添加内置动作&quot;。" />

        <ScrollViewer Grid.Row="2" Padding="20,0,20,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- URL -->
                <Border Style="{StaticResource Settings.Card}" Padding="14" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Link24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Margin="8,0,0,0"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Text="URL 动作" />
                            </StackPanel>
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource Settings.SubtleForeground}"
                                       TextWrapping="Wrap"
                                       Text="按一个 URL 模板打开浏览器；占位符 {q} 是选区文本（URL 编码后），{text} 是原文。" />
                        </StackPanel>
                        <ui:Button Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Appearance="Primary"
                                   Content="创建"
                                   Click="OnCreateUrl" />
                    </Grid>
                </Border>

                <!-- AI 空白 -->
                <Border Style="{StaticResource Settings.Card}" Padding="14" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Margin="8,0,0,0"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Text="AI 自定义动作" />
                            </StackPanel>
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource Settings.SubtleForeground}"
                                       TextWrapping="Wrap"
                                       Text="自己写 Prompt 模板，自由组合 system / user 消息和占位符。" />
                        </StackPanel>
                        <ui:Button Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Appearance="Primary"
                                   Content="创建"
                                   Click="OnCreateBlankAi" />
                    </Grid>
                </Border>

                <!-- 从模板派生 -->
                <Border Style="{StaticResource Settings.Card}" Padding="14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Text="从内置 AI 模板派生" />
                        </StackPanel>
                        <TextBlock Margin="0,4,0,10"
                                   FontSize="12"
                                   Foreground="{DynamicResource Settings.SubtleForeground}"
                                   TextWrapping="Wrap"
                                   Text="基于内置 Prompt 模板复制一份成可编辑的用户动作；同一模板可以派生多次。" />
                        <ItemsControl ItemsSource="{Binding Templates, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Settings.Card.SubtleBackground}"
                                            BorderBrush="{DynamicResource Settings.Stroke}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Settings.Radius.Sm}"
                                            Padding="10,8"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold" />
                                                    <Border Margin="8,0,0,0"
                                                            Background="{DynamicResource Settings.AccentSoft}"
                                                            CornerRadius="6"
                                                            Padding="5,1"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding OutputMode}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource Settings.Accent}" />
                                                    </Border>
                                                    <TextBlock Margin="8,0,0,0"
                                                               FontSize="10.5"
                                                               Foreground="{DynamicResource Settings.Muted}"
                                                               Text="（已被内置 AI 动作覆盖）"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasBuiltInCounterpart, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,3,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{DynamicResource Settings.SubtleForeground}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ui:Button Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Appearance="Secondary"
                                                       Content="派生"
                                                       Tag="{Binding}"
                                                       Click="OnDeriveFromTemplate" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="20,10,20,12"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="关闭" Click="OnCloseClicked" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
