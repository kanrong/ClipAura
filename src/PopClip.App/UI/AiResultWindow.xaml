<ui:FluentWindow x:Class="PopClip.App.UI.AiResultWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="ClipAura AI"
                 Width="880"
                 Height="720"
                 MinWidth="640"
                 MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 FontFamily="{StaticResource Settings.FontFamily}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar"
                     Grid.Row="0"
                     Title="ClipAura AI"
                     Style="{StaticResource Settings.CompactTitleBar}"
                     ShowMaximize="True"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Sparkle24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="12,6,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="ReferencePanel"
                    Grid.Row="0"
                    Background="{DynamicResource Settings.Card.SubtleBackground}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="8,2,8,2"
                    Margin="0,0,0,6">
                <Expander x:Name="ReferenceExpander"
                          IsExpanded="False">
                    <ScrollViewer MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,6,0,4">
                        <TextBlock x:Name="ReferenceText"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Settings.SubtleForeground}" />
                    </ScrollViewer>
                </Expander>
            </Border>

            <ProgressBar x:Name="LoadingBar"
                         Grid.Row="1"
                         Height="3"
                         IsIndeterminate="True"
                         Visibility="Collapsed"
                         Margin="0,0,0,6" />

            <Border Grid.Row="2"
                    Background="{DynamicResource Settings.Card.Background}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="8">
                <ScrollViewer x:Name="MessagesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="MessagesPanel" />
                </ScrollViewer>
            </Border>

            <!-- 变体快捷条：让用户对最新回复一键追问"更短/更长/更专业..." -->
            <StackPanel x:Name="VariantPanel"
                        Grid.Row="3"
                        Orientation="Horizontal"
                        Margin="0,4,0,2">
                <StackPanel.Resources>
                    <Style x:Key="VariantChip" TargetType="Button">
                        <Setter Property="Margin" Value="0,0,6,0" />
                        <Setter Property="Padding" Value="10,4" />
                        <Setter Property="MinHeight" Value="24" />
                        <Setter Property="FontSize" Value="11.5" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Background" Value="{DynamicResource Settings.Card.SubtleBackground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Settings.Stroke}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Foreground" Value="{DynamicResource Settings.SubtleForeground}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="11"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Settings.Hover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Resources>
                <Button Style="{StaticResource VariantChip}" Content="更短"
                        Tag="基于上一条回复，给出更精炼、更简短的版本。只输出新版本，不要解释。"
                        Click="OnVariantClicked" />
                <Button Style="{StaticResource VariantChip}" Content="更详细"
                        Tag="基于上一条回复，补充更多细节、示例与背景。"
                        Click="OnVariantClicked" />
                <Button Style="{StaticResource VariantChip}" Content="更专业"
                        Tag="把上一条回复改写为更专业、正式的语气，适合写入正式文档。只输出新版本。"
                        Click="OnVariantClicked" />
                <Button Style="{StaticResource VariantChip}" Content="更口语"
                        Tag="把上一条回复改写为口语化、自然的表达。只输出新版本。"
                        Click="OnVariantClicked" />
                <Button Style="{StaticResource VariantChip}" Content="译为英文"
                        Tag="把上一条回复翻译为英文。只输出译文。"
                        Click="OnVariantClicked" />
                <Button Style="{StaticResource VariantChip}" Content="译为中文"
                        Tag="把上一条回复翻译为简体中文。只输出译文。"
                        Click="OnVariantClicked" />
                <Button Style="{StaticResource VariantChip}" Content="重新生成"
                        Tag="regenerate"
                        Click="OnRegenerateClicked" />
                <Button Style="{StaticResource VariantChip}" Content="继续"
                        Tag="continue"
                        Click="OnContinueClicked" />
            </StackPanel>

            <Grid Grid.Row="4" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="QuestionBox"
                            Grid.Column="0"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="68"
                            MaxHeight="140"
                            Padding="10,8"
                            PlaceholderText="输入问题，按 Ctrl+Enter 发送"
                            KeyDown="OnQuestionKeyDown" />
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            VerticalAlignment="Stretch"
                            Margin="8,0,0,0">
                    <ui:Button x:Name="SendButton"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon Send24}"
                               Content="发送"
                               Width="92"
                               VerticalAlignment="Stretch"
                               Click="OnSendClicked" />
                    <ui:Button x:Name="StopButton"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Stop24}"
                               Content="停止"
                               Width="92"
                               Margin="0,6,0,0"
                               Visibility="Collapsed"
                               Click="OnStopClicked" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource Settings.Card.Background}"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="MetaText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource Settings.SubtleForeground}"
                           FontSize="{StaticResource Settings.FontSize.Body}"
                           Margin="0,0,12,0" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <ui:Button Appearance="Secondary"
                               Content="关闭"
                               MinWidth="78"
                               Margin="0,0,8,0"
                               Click="OnCloseClicked" />
                    <ui:Button Appearance="Secondary"
                               x:Name="CopyButton"
                               Icon="{ui:SymbolIcon Copy24}"
                               Content="复制最新回复"
                               MinWidth="128"
                               Margin="0,0,8,0"
                               Click="OnCopyClicked" />
                    <ui:Button Appearance="Primary"
                               x:Name="ReplaceButton"
                               Icon="{ui:SymbolIcon Edit24}"
                               Content="替换选中文本"
                               MinWidth="132"
                               Click="OnReplaceClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
