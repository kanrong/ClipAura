<ui:FluentWindow x:Class="PopClip.App.UI.AiResultWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="ClipAura AI"
                 Width="880"
                 Height="720"
                 MinWidth="640"
                 MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 FontFamily="{StaticResource Settings.FontFamily}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar"
                     Grid.Row="0"
                     Title="ClipAura AI"
                     ShowMaximize="True"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Sparkle24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="12,6,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="ReferencePanel"
                    Grid.Row="0"
                    Background="{DynamicResource Settings.Card.SubtleBackground}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="8,2,8,2"
                    Margin="0,0,0,6">
                <Expander x:Name="ReferenceExpander"
                          IsExpanded="False">
                    <ScrollViewer MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,6,0,4">
                        <TextBlock x:Name="ReferenceText"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Settings.SubtleForeground}" />
                    </ScrollViewer>
                </Expander>
            </Border>

            <ProgressBar x:Name="LoadingBar"
                         Grid.Row="1"
                         Height="3"
                         IsIndeterminate="True"
                         Visibility="Collapsed"
                         Margin="0,0,0,6" />

            <Border Grid.Row="2"
                    Background="{DynamicResource Settings.Card.Background}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="8">
                <ScrollViewer x:Name="MessagesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="MessagesPanel" />
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="3" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="QuestionBox"
                            Grid.Column="0"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="68"
                            MaxHeight="140"
                            Padding="10,8"
                            PlaceholderText="输入问题，按 Ctrl+Enter 发送"
                            KeyDown="OnQuestionKeyDown" />
                <ui:Button x:Name="SendButton"
                           Grid.Column="1"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Send24}"
                           Content="发送"
                           Width="92"
                           Margin="8,0,0,0"
                           VerticalAlignment="Stretch"
                           Click="OnSendClicked" />
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource Settings.Card.Background}"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="MetaText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource Settings.SubtleForeground}"
                           FontSize="{StaticResource Settings.FontSize.Body}"
                           Margin="0,0,12,0" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <ui:Button Appearance="Secondary"
                               Content="关闭"
                               MinWidth="78"
                               Margin="0,0,8,0"
                               Click="OnCloseClicked" />
                    <ui:Button Appearance="Secondary"
                               x:Name="CopyButton"
                               Icon="{ui:SymbolIcon Copy24}"
                               Content="复制最新回复"
                               MinWidth="128"
                               Margin="0,0,8,0"
                               Click="OnCopyClicked" />
                    <ui:Button Appearance="Primary"
                               x:Name="ReplaceButton"
                               Icon="{ui:SymbolIcon Edit24}"
                               Content="替换选中文本"
                               MinWidth="132"
                               Click="OnReplaceClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
