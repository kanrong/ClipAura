<ui:FluentWindow x:Class="PopClip.App.UI.ClipboardHistoryWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 x:ClassModifier="internal"
                 Title="ClipAura 剪贴板历史"
                 Width="620"
                 Height="560"
                 MinWidth="420"
                 MinHeight="360"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 Foreground="{DynamicResource Settings.Foreground}"
                 FontFamily="{DynamicResource Settings.FontFamily}">
    <Grid Background="{DynamicResource Settings.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="剪贴板历史"
                     Style="{StaticResource Settings.CompactTitleBar}"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="History24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ui:TextBox Grid.Row="1"
                    x:Name="SearchBox"
                    Margin="14,8,14,8"
                    PlaceholderText="搜索历史 (ESC 关闭)"
                    Icon="{ui:SymbolIcon Search24}"
                    TextChanged="OnSearchChanged"
                    KeyDown="OnSearchKeyDown" />

        <Border Grid.Row="2"
                Margin="14,0,14,8"
                Background="{DynamicResource Settings.Card.Background}"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="1"
                CornerRadius="{StaticResource Settings.Radius.Md}">
            <ListBox x:Name="HistoryList"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnItemDoubleClick"
                     KeyDown="OnListKeyDown">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="4,2" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Preview}"
                                           Grid.Column="0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="13"
                                           Foreground="{DynamicResource Settings.Foreground}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimeLabel}"
                                           FontSize="11"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource Settings.Muted}" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding MetaLabel}"
                                       FontSize="11"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource Settings.Muted}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="3"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="HintText"
                           VerticalAlignment="Center"
                           FontSize="11.5"
                           Foreground="{DynamicResource Settings.SubtleForeground}"
                           Text="Enter 粘贴 · Ctrl+Enter 仅复制 · Del 删除 · P 钉选" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Appearance="Secondary"
                               Content="复制"
                               Margin="0,0,6,0"
                               Click="OnCopyClicked" />
                    <ui:Button Appearance="Primary"
                               Content="粘贴"
                               Click="OnPasteClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
