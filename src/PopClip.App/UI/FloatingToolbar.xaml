<Window x:Class="PopClip.App.UI.FloatingToolbar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:PopClip.App.UI"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource ToolbarFontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <local:IconKeyToMaterialDesignKindConverter x:Key="MaterialIconConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 浮窗按钮悬停 tooltip 的样式：系统默认 Padding 偏大（约 8,4 + 行高 padding），
             在 12 字号小提示上显得粗壮。这里收紧为 8,2，让 tooltip 紧贴文字，
             并把字号显式收到 12 与浮窗一致。仅作用于浮窗自身的 ToolTip，不影响设置窗口 -->
        <Style TargetType="ToolTip">
            <Setter Property="Padding" Value="8,2,8,2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>
    </Window.Resources>

    <!-- Margin 与 FloatingToolbar.xaml.cs ShadowPaddingDip 必须严格相等，否则
         窗口定位会与阴影外缘错位；这里 12 留给 BlurRadius=10 + Depth=3 的纯阴影模式不被裁切 -->
    <Grid Margin="12"
          SnapsToDevicePixels="True">
        <!-- 阴影底板：fill 必须与主体 ToolbarBackground 同色，主 Border 完全覆盖其填充区，
             只露出 DropShadowEffect 投射出来的柔和阴影。
             这样既不会在主体边缘形成"深色硬边"，也保留主 Border 内文本的 ClearType 渲染。
             CornerRadius 与主 Border 严格一致，避免"内圆外方"双圆角；
             Direction=270 让阴影自然向下沉，符合人眼对重力光源的预期 -->
        <Border Background="{DynamicResource ToolbarBackground}"
                CornerRadius="{DynamicResource ToolbarCornerRadius}"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000"
                                  Direction="270"
                                  BlurRadius="{DynamicResource ToolbarShadowBlurRadius}"
                                  ShadowDepth="{DynamicResource ToolbarShadowDepth}"
                                  Opacity="{DynamicResource ToolbarShadowOpacity}"
                                  RenderingBias="Performance" />
            </Border.Effect>
        </Border>

        <!-- 内容层：按钮区。三层结构（阴影底板 → ContentClipHost → 描边层）的关键中间层。
             不再嵌在带 BorderBrush 的 Border 里，避免"Border.Background 圆角在 BorderBrush 内侧
             留半像素抗锯齿过渡区"导致的"圆角处 1px 白边"。
             ContentClipHost 直接占据整个 Grid（与阴影底板同尺寸），Clip 圆角 = 外圆角，
             按钮 hover 高亮直接铺满到外圆角弧线，描边层在最上面把 hover 边缘的 0.5px 模糊咬住 -->
        <Grid x:Name="ContentClipHost"
              SizeChanged="OnContentClipHostSizeChanged"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <!-- 外层 ItemsControl 绑定 Rows（多行布局时 ≥2 个 row，单行布局始终 1 个），
                 内层 ItemsControl 绑定 row.Items 用 WrapPanel 展示按钮。
                 这样布局策略（默认 / 智能动作单独一行 / 按分组多行）只影响 Rows 的拆分，
                 单个按钮 ItemTemplate 一份代码两层共用 -->
            <ItemsControl x:Name="RowsHost"
                          ItemsSource="{Binding Rows, RelativeSource={RelativeSource AncestorType=Window}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               Margin="{DynamicResource ToolbarItemsPanelMargin}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding Command}"
                                            ToolTip="{Binding Title}">
                                        <!-- 图标在上、文字在下：与"外观页实时预览"卡片保持完全一致；
                                             IconOnly 模式时文字折叠，TextOnly 模式时图标折叠，按钮高度自适应 -->
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterialDesign Kind="{Binding IconKey, Converter={StaticResource MaterialIconConv}}"
                                                                              Width="{DynamicResource ToolbarIconFontSize}"
                                                                              Height="{DynamicResource ToolbarIconFontSize}"
                                                                              HorizontalAlignment="Center"
                                                                              Visibility="{Binding DataContext.IsIconVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                <iconPacks:PackIconMaterialDesign.Style>
                                                    <Style TargetType="iconPacks:PackIconMaterialDesign">
                                                        <!-- 图标下方与文字之间留 2px：仅图标模式时清零，避免按钮多出空白边 -->
                                                        <Setter Property="Margin" Value="0,0,0,2" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsTextVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                <Setter Property="Margin" Value="0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconMaterialDesign.Style>
                                            </iconPacks:PackIconMaterialDesign>
                                            <TextBlock Text="{Binding Title}"
                                                       HorizontalAlignment="Center"
                                                       Visibility="{Binding DataContext.IsTextVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- 描边层：仅画 1px 圆角描边，IsHitTestVisible=False 不拦点击；
             叠在最上面把 ContentClipHost 内 hover 边缘的 0.5px 抗锯齿过渡区咬住，
             视觉上 hover 颜色 ↔ 边框 ↔ 圆角弧线连成一体，圆角处不再有任何浅色透出 -->
        <Border BorderBrush="{DynamicResource ToolbarBorder}"
                BorderThickness="{DynamicResource ToolbarBorderThickness}"
                CornerRadius="{DynamicResource ToolbarCornerRadius}"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True" />
    </Grid>
</Window>
