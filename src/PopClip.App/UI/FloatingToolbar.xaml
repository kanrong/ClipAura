<Window x:Class="PopClip.App.UI.FloatingToolbar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PopClip.App.UI"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{StaticResource ToolbarBackground}"
            BorderThickness="0"
            CornerRadius="10"
            Padding="0"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="14" ShadowDepth="2" Opacity="0.45" />
        </Border.Effect>

        <ItemsControl x:Name="ItemsHost" ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=Window}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding Command}"
                            ToolTip="{Binding Title}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IconKey, Converter={StaticResource IconConv}}"
                                       FontFamily="{Binding IconKey, Converter={StaticResource IconFontConv}}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsIconVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Margin" Value="0,0,6,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsTextVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Margin" Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsTextVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>
