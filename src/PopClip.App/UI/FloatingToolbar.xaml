<Window x:Class="PopClip.App.UI.FloatingToolbar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PopClip.App.UI"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, 微软雅黑, PingFang SC, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 浮窗内的"复制"小按钮：屏蔽全局 WPF-UI Fluent 默认样式，保持极简紧凑的外观 -->
        <Style x:Key="ToolbarToastButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarForeground}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolbarHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="9"
          SnapsToDevicePixels="True">
        <!-- 阴影底板：fill 必须与主体 ToolbarBackground 同色，主 Border 完全覆盖其填充区，
             只露出 DropShadowEffect 投射出来的柔和阴影。
             这样既不会在主体边缘形成"深色硬边"，也保留主 Border 内文本的 ClearType 渲染。
             CornerRadius 与主 Border 严格一致，避免"内圆外方"双圆角；
             Direction=270 让阴影自然向下沉，符合人眼对重力光源的预期 -->
        <Border Background="{DynamicResource ToolbarBackground}"
                CornerRadius="{DynamicResource ToolbarCornerRadius}"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000"
                                  Direction="270"
                                  BlurRadius="{DynamicResource ToolbarShadowBlurRadius}"
                                  ShadowDepth="{DynamicResource ToolbarShadowDepth}"
                                  Opacity="{DynamicResource ToolbarShadowOpacity}"
                                  RenderingBias="Performance" />
            </Border.Effect>
        </Border>

        <!-- 内容层：按钮区。三层结构（阴影底板 → ContentClipHost → 描边层）的关键中间层。
             不再嵌在带 BorderBrush 的 Border 里，避免"Border.Background 圆角在 BorderBrush 内侧
             留半像素抗锯齿过渡区"导致的"圆角处 1px 白边"。
             ContentClipHost 直接占据整个 Grid（与阴影底板同尺寸），Clip 圆角 = 外圆角，
             按钮 hover 高亮直接铺满到外圆角弧线，描边层在最上面把 hover 边缘的 0.5px 模糊咬住 -->
        <Grid x:Name="ContentClipHost"
              SizeChanged="OnContentClipHostSizeChanged"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <StackPanel>
                <ItemsControl x:Name="ItemsHost" ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                                       Margin="{DynamicResource ToolbarItemsPanelMargin}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding Command}"
                                    ToolTip="{Binding Title}">
                                <StackPanel Orientation="Horizontal">
                                    <!-- 图标：比正文大 4 号 + SemiBold；
                                         对 Segoe Fluent Icons 字体而言字重影响很小，但对
                                         普通字符/emoji 起到加粗强调，整体让图标成为按钮焦点 -->
                                    <TextBlock Text="{Binding IconKey, Converter={StaticResource IconConv}}"
                                               FontFamily="{Binding IconKey, Converter={StaticResource IconFontConv}}"
                                               FontSize="{DynamicResource ToolbarIconFontSize}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding DataContext.IsIconVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="0,0,6,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTextVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                        <Setter Property="Margin" Value="0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding DataContext.IsTextVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border x:Name="ToastHost"
                        Background="{DynamicResource ToolbarToastBackground}"
                        CornerRadius="3"
                        Margin="3,2,3,3"
                        Padding="8,5"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <Button x:Name="ToastCopyButton"
                                Style="{StaticResource ToolbarToastButtonStyle}"
                                Content="复制"
                                DockPanel.Dock="Right"
                                Margin="8,0,0,0"
                                Padding="6,2"
                                Click="OnCopyToastClicked"
                                Visibility="Collapsed" />
                        <TextBlock x:Name="ToastText"
                                   Foreground="{DynamicResource ToolbarForeground}"
                                   TextWrapping="Wrap" />
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- 描边层：仅画 1px 圆角描边，IsHitTestVisible=False 不拦点击；
             叠在最上面把 ContentClipHost 内 hover 边缘的 0.5px 抗锯齿过渡区咬住，
             视觉上 hover 颜色 ↔ 边框 ↔ 圆角弧线连成一体，圆角处不再有任何浅色透出 -->
        <Border BorderBrush="{DynamicResource ToolbarBorder}"
                BorderThickness="{DynamicResource ToolbarBorderThickness}"
                CornerRadius="{DynamicResource ToolbarCornerRadius}"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True" />
    </Grid>
</Window>
