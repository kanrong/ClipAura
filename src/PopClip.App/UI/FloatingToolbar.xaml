<Window x:Class="PopClip.App.UI.FloatingToolbar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PopClip.App.UI"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
    </Window.Resources>

    <Border Background="{StaticResource ToolbarBackground}"
            BorderBrush="{StaticResource ToolbarBorder}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="4"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="14" ShadowDepth="2" Opacity="0.45" />
        </Border.Effect>

        <ItemsControl x:Name="ItemsHost" ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=Window}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding Command}"
                            ToolTip="{Binding Title}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IconKey, Converter={StaticResource IconConv}}"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="14"
                                       Margin="0,0,4,0" />
                            <TextBlock Text="{Binding Title}" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>
