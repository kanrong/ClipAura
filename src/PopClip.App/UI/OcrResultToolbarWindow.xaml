<Window x:Class="PopClip.App.UI.OcrResultToolbarWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Focusable="False"
        ShowActivated="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Title="OCR 工具条"
        FontFamily="{DynamicResource ToolbarFontFamily}">

    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource ToolbarHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource ToolbarAccentSoft}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrToolbarSepStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="1" />
            <Setter Property="Margin" Value="4,4" />
            <Setter Property="Fill" Value="{DynamicResource ToolbarSeparator}" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
    </Window.Resources>

    <!-- 阴影靠 Border.Effect 单独实现；外层留点 margin 给阴影留位 -->
    <Grid Margin="6">
        <Border x:Name="ToolbarBorder"
                Padding="4,4"
                Background="{DynamicResource ToolbarToastBackground}"
                BorderBrush="{DynamicResource ToolbarBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.4" Color="Black" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 拖动 grip：响应 MouseLeftButtonDown → Window.DragMove() 拖到屏幕任意位置 -->
                <Border x:Name="ToolbarGrip"
                        Background="Transparent"
                        Cursor="SizeAll"
                        Padding="6,0"
                        VerticalAlignment="Stretch"
                        Margin="0,0,2,0"
                        ToolTip="按住拖动可移动到屏幕任意位置">
                    <TextBlock Foreground="{DynamicResource ToolbarForeground}"
                               Opacity="0.45"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Text="⋮⋮" />
                </Border>

                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource ToolbarForeground}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="2,0,8,0" />

                <Rectangle Style="{StaticResource OcrToolbarSepStyle}" />

                <Button x:Name="CopySelectedButton"
                        Style="{StaticResource ToolButtonStyle}"
                        Content="复制选中"
                        Click="OnCopySelected" />
                <Button x:Name="CopyAllButton"
                        Style="{StaticResource ToolButtonStyle}"
                        Content="复制全部"
                        Click="OnCopyAll" />

                <Rectangle x:Name="TranslateSep"
                           Style="{StaticResource OcrToolbarSepStyle}"
                           Visibility="Collapsed" />

                <!-- 翻译按钮仅在 AI 启用时可见 -->
                <Button x:Name="TranslateSelectedButton"
                        Style="{StaticResource ToolButtonStyle}"
                        Content="翻译选中"
                        Click="OnTranslateSelected"
                        Visibility="Collapsed" />
                <Button x:Name="TranslateAllButton"
                        Style="{StaticResource ToolButtonStyle}"
                        Content="翻译全部"
                        Click="OnTranslateAll"
                        Visibility="Collapsed" />
                <Button x:Name="TranslateClearButton"
                        Style="{StaticResource ToolButtonStyle}"
                        Content="清除译文"
                        Click="OnTranslateClear"
                        Visibility="Collapsed" />

                <Rectangle Style="{StaticResource OcrToolbarSepStyle}" />

                <Button Style="{StaticResource ToolButtonStyle}"
                        Content="Quick 输出"
                        Click="OnSwitchToQuick"
                        ToolTip="把本次结果按 Quick 模式输出：复制全文 + 浮窗气泡（仅本次，不修改设置）" />
                <Button Style="{StaticResource ToolButtonStyle}"
                        Content="关闭"
                        Click="OnCloseClicked"
                        ToolTip="关闭 (Esc)" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
