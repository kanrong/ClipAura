<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         设置窗口的"页面级 token + 骨架样式"
         控件级样式（TextBox / Button / ComboBox / CheckBox / RadioButton 等）
         全部交给 WPF-UI 的 ControlsDictionary，此处不再自定义，避免双套样式打架。
         ============================================================ -->

    <!-- 颜色 / 画刷（语义层）-->
    <SolidColorBrush x:Key="Settings.Window.Background" Color="#F5F6F9" />
    <SolidColorBrush x:Key="Settings.Sidebar.Background" Color="#ECEFF4" />
    <SolidColorBrush x:Key="Settings.Sidebar.SelectedBackground" Color="#E1ECFE" />
    <SolidColorBrush x:Key="Settings.Sidebar.HoverBackground" Color="#E4E7EE" />
    <SolidColorBrush x:Key="Settings.Card.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Settings.Card.Border" Color="#E2E6ED" />
    <SolidColorBrush x:Key="Settings.Card.SubtleBackground" Color="#F9FAFB" />
    <SolidColorBrush x:Key="Settings.Foreground" Color="#1C2230" />
    <SolidColorBrush x:Key="Settings.SubtleForeground" Color="#5B6577" />
    <SolidColorBrush x:Key="Settings.Muted" Color="#9097A6" />
    <SolidColorBrush x:Key="Settings.Stroke" Color="#D9DEE7" />
    <SolidColorBrush x:Key="Settings.Accent" Color="#2563EB" />
    <SolidColorBrush x:Key="Settings.AccentHover" Color="#1D4ED8" />
    <SolidColorBrush x:Key="Settings.AccentForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Settings.AccentSoft" Color="#E5EEFF" />
    <SolidColorBrush x:Key="Settings.Input.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Settings.Input.Border" Color="#CBD2DC" />
    <SolidColorBrush x:Key="Settings.Input.BorderFocused" Color="#2563EB" />
    <SolidColorBrush x:Key="Settings.Hover" Color="#EEF1F6" />
    <SolidColorBrush x:Key="Settings.SuccessSoft" Color="#E5F7EE" />
    <SolidColorBrush x:Key="Settings.Success" Color="#15803D" />
    <SolidColorBrush x:Key="Settings.DangerSoft" Color="#FCE7EA" />
    <SolidColorBrush x:Key="Settings.Danger" Color="#C2261B" />
    <SolidColorBrush x:Key="Settings.WarningSoft" Color="#FEF3C7" />
    <SolidColorBrush x:Key="Settings.Warning" Color="#92400E" />

    <!-- 圆角 / 间距 token -->
    <CornerRadius x:Key="Settings.Radius.Sm">4</CornerRadius>
    <CornerRadius x:Key="Settings.Radius.Md">6</CornerRadius>
    <CornerRadius x:Key="Settings.Radius.Lg">10</CornerRadius>
    <Thickness x:Key="Settings.Padding.Card">18</Thickness>
    <sys:Double x:Key="Settings.FontSize.Body">13</sys:Double>
    <sys:Double x:Key="Settings.FontSize.Section">16</sys:Double>
    <sys:Double x:Key="Settings.FontSize.Page">22</sys:Double>
    <!-- 字体回退链：中文环境优先（Microsoft YaHei UI / 微软雅黑），缺中文字形再回落到 Segoe -->
    <FontFamily x:Key="Settings.FontFamily">Microsoft YaHei UI, Microsoft YaHei, 微软雅黑, PingFang SC, Segoe UI Variable Display, Segoe UI</FontFamily>

    <!-- ============================================================
         通用排版（页面级，不影响控件）
         ============================================================ -->

    <Style x:Key="Settings.PageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Settings.FontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource Settings.FontSize.Page}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Settings.Foreground}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="Settings.PageDescription" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Settings.FontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource Settings.FontSize.Body}" />
        <Setter Property="Foreground" Value="{DynamicResource Settings.SubtleForeground}" />
        <Setter Property="Margin" Value="0,0,0,18" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Settings.SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Settings.FontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource Settings.FontSize.Section}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Settings.Foreground}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="Settings.FieldLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Settings.FontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource Settings.FontSize.Body}" />
        <Setter Property="Foreground" Value="{DynamicResource Settings.SubtleForeground}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="Settings.HintText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Settings.FontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource Settings.Muted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- ============================================================
         Card / Section（Border 容器，不与 WPF-UI 控件冲突）
         ============================================================ -->

    <Style x:Key="Settings.Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Settings.Card.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Settings.Card.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Settings.Radius.Lg}" />
        <Setter Property="Padding" Value="{StaticResource Settings.Padding.Card}" />
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Settings.SubCard" TargetType="Border" BasedOn="{StaticResource Settings.Card}">
        <Setter Property="Background" Value="{DynamicResource Settings.Card.SubtleBackground}" />
        <Setter Property="CornerRadius" Value="{StaticResource Settings.Radius.Md}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ============================================================
         侧边栏导航项（ListBoxItem 自定义模板）
         ============================================================ -->

    <Style x:Key="Settings.NavItem" TargetType="ListBoxItem">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource Settings.Foreground}" />
        <Setter Property="FontFamily" Value="{StaticResource Settings.FontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource Settings.FontSize.Body}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="{StaticResource Settings.Radius.Sm}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Indicator"
                                    Grid.Column="0"
                                    Width="3"
                                    Background="Transparent"
                                    CornerRadius="2"
                                    Margin="0,4,8,4" />
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Settings.Sidebar.HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Settings.Sidebar.SelectedBackground}" />
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Settings.Accent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
