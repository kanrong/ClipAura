<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ToolbarLightBackground" Color="#FAFAFA" Opacity="0.98" />
    <!-- ToolbarShadow 已不再作为阴影底板的可见 fill 使用（改为与 Background 同色），
         此处保留资源是为了在主题切换代码里维持向前兼容；DropShadowEffect 颜色固定为黑色 -->
    <SolidColorBrush x:Key="ToolbarLightShadow" Color="#000000" Opacity="0.16" />
    <!-- 细边框颜色与主体背景同色相近，避免圆角处对比过强产生"硬切感" -->
    <SolidColorBrush x:Key="ToolbarLightBorder" Color="#E3E7EE" Opacity="1" />
    <SolidColorBrush x:Key="ToolbarLightForeground" Color="#242424" />
    <SolidColorBrush x:Key="ToolbarLightHover" Color="#EDEDED" />
    <SolidColorBrush x:Key="ToolbarLightAccentSoft" Color="#DCEBFF" />
    <SolidColorBrush x:Key="ToolbarLightToastBackground" Color="#EFF6FF" />
    <SolidColorBrush x:Key="ToolbarLightSeparator" Color="#D8D8D8" />

    <SolidColorBrush x:Key="ToolbarDarkBackground" Color="#262626" Opacity="0.96" />
    <SolidColorBrush x:Key="ToolbarDarkShadow" Color="#000000" Opacity="0.24" />
    <SolidColorBrush x:Key="ToolbarDarkBorder" Color="#3F454D" Opacity="1" />
    <SolidColorBrush x:Key="ToolbarDarkForeground" Color="#F5F5F5" />
    <SolidColorBrush x:Key="ToolbarDarkHover" Color="#3A3A3A" />
    <SolidColorBrush x:Key="ToolbarDarkAccentSoft" Color="#253B56" />
    <SolidColorBrush x:Key="ToolbarDarkToastBackground" Color="#30363D" />
    <SolidColorBrush x:Key="ToolbarDarkSeparator" Color="#555555" />

    <StaticResource x:Key="ToolbarBackground" ResourceKey="ToolbarLightBackground" />
    <StaticResource x:Key="ToolbarShadow" ResourceKey="ToolbarLightShadow" />
    <StaticResource x:Key="ToolbarBorder" ResourceKey="ToolbarLightBorder" />
    <StaticResource x:Key="ToolbarForeground" ResourceKey="ToolbarLightForeground" />
    <StaticResource x:Key="ToolbarHover" ResourceKey="ToolbarLightHover" />
    <StaticResource x:Key="ToolbarAccentSoft" ResourceKey="ToolbarLightAccentSoft" />
    <StaticResource x:Key="ToolbarToastBackground" ResourceKey="ToolbarLightToastBackground" />
    <StaticResource x:Key="ToolbarSeparator" ResourceKey="ToolbarLightSeparator" />
    <CornerRadius x:Key="ToolbarCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="ToolbarButtonCornerRadius">3</CornerRadius>
    <Thickness x:Key="ToolbarBorderThickness">1</Thickness>
    <Thickness x:Key="ToolbarButtonPadding">10,4</Thickness>
    <Thickness x:Key="ToolbarButtonMargin">1</Thickness>
    <!-- 阴影默认值（ShadowAndBorder 风格）。Margin=9 留给阴影外扩的空间约 9 DIP，
         因此 BlurRadius + ShadowDepth 之和不宜超过 ~14，否则阴影会被透明窗口边界裁切 -->
    <sys:Double x:Key="ToolbarShadowBlurRadius" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="ToolbarShadowDepth" xmlns:sys="clr-namespace:System;assembly=mscorlib">2</sys:Double>
    <sys:Double x:Key="ToolbarShadowOpacity" xmlns:sys="clr-namespace:System;assembly=mscorlib">0.16</sys:Double>
    <sys:Double x:Key="ToolbarButtonFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="ToolbarIconFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarForeground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{DynamicResource ToolbarButtonPadding}" />
        <Setter Property="Margin" Value="{DynamicResource ToolbarButtonMargin}" />
        <Setter Property="FontSize" Value="{DynamicResource ToolbarButtonFontSize}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource ToolbarButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolbarHover}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsKeyboardSelected}" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolbarAccentSoft}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
