<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ToolbarLightBackground" Color="#FAFAFA" Opacity="0.98" />
    <SolidColorBrush x:Key="ToolbarLightShadow" Color="#111827" Opacity="0.10" />
    <SolidColorBrush x:Key="ToolbarLightForeground" Color="#242424" />
    <SolidColorBrush x:Key="ToolbarLightHover" Color="#EDEDED" />
    <SolidColorBrush x:Key="ToolbarLightSeparator" Color="#D8D8D8" />

    <SolidColorBrush x:Key="ToolbarDarkBackground" Color="#262626" Opacity="0.96" />
    <SolidColorBrush x:Key="ToolbarDarkShadow" Color="#262626" Opacity="0.18" />
    <SolidColorBrush x:Key="ToolbarDarkForeground" Color="#F5F5F5" />
    <SolidColorBrush x:Key="ToolbarDarkHover" Color="#3A3A3A" />
    <SolidColorBrush x:Key="ToolbarDarkSeparator" Color="#555555" />

    <StaticResource x:Key="ToolbarBackground" ResourceKey="ToolbarLightBackground" />
    <StaticResource x:Key="ToolbarShadow" ResourceKey="ToolbarLightShadow" />
    <StaticResource x:Key="ToolbarForeground" ResourceKey="ToolbarLightForeground" />
    <StaticResource x:Key="ToolbarHover" ResourceKey="ToolbarLightHover" />
    <StaticResource x:Key="ToolbarSeparator" ResourceKey="ToolbarLightSeparator" />

    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarForeground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolbarHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
