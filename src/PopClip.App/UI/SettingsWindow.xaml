<ui:FluentWindow x:Class="PopClip.App.UI.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:PopClip.App.UI"
                 Title="ClipAura 设置"
                 Width="1020" Height="700"
                 MinWidth="880" MinHeight="600"
                 ShowInTaskbar="True"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 FontFamily="{StaticResource Settings.FontFamily}"
                 UseLayoutRounding="True"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 每条 Action 卡片的 DataTemplate -->
        <DataTemplate x:Key="ActionItemTemplate" DataType="{x:Type local:ActionEditorItem}">
            <Border Background="{DynamicResource Settings.Card.Background}"
                    BorderBrush="{DynamicResource Settings.Card.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="14"
                    Margin="0,0,0,10"
                    SnapsToDevicePixels="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- 主行 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="148" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 拖拽柄 -->
                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="ReOrderDotsVertical24"
                                       FontSize="14"
                                       Foreground="{DynamicResource Settings.Muted}"
                                       VerticalAlignment="Center"
                                       Cursor="SizeAll"
                                       ToolTip="拖拽以重排" />

                        <!-- 图标预览 -->
                        <Border Grid.Column="1"
                                Width="32" Height="32"
                                Background="{DynamicResource Settings.AccentSoft}"
                                CornerRadius="{StaticResource Settings.Radius.Sm}"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding Icon, Converter={StaticResource IconConv}}"
                                       FontFamily="{Binding Icon, Converter={StaticResource IconFontConv}}"
                                       FontSize="16"
                                       Foreground="{DynamicResource Settings.Accent}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <!-- 标题 + ID -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                            <ui:TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Padding="0,2" />
                            <ui:TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="11"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="{DynamicResource Settings.Muted}"
                                        Padding="0,2"
                                        ToolTip="动作 ID（用于 actions.json）" />
                        </StackPanel>

                        <!-- 类型下拉 -->
                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding DataContext.ActionTypeChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0" />

                        <!-- 启用开关 -->
                        <ui:ToggleSwitch Grid.Column="4"
                                         IsChecked="{Binding Enabled}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"
                                         ToolTip="启用此动作" />

                        <!-- 操作按钮 -->
                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon ArrowUp24}"
                                       Tag="{Binding}"
                                       Click="OnActionMoveUp"
                                       Padding="6"
                                       ToolTip="上移" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon ArrowDown24}"
                                       Tag="{Binding}"
                                       Click="OnActionMoveDown"
                                       Padding="6"
                                       Margin="2,0,0,0"
                                       ToolTip="下移" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Tag="{Binding}"
                                       Click="OnActionDelete"
                                       Padding="6"
                                       Margin="2,0,0,0"
                                       Foreground="{DynamicResource Settings.Danger}"
                                       ToolTip="删除" />
                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="6"
                                          Margin="2,0,0,0"
                                          ToolTip="展开 / 折叠详情">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Settings.Hover}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                                <ToggleButton.Content>
                                    <ui:SymbolIcon x:Name="ChevronIcon"
                                                   Symbol="ChevronDown24"
                                                   FontSize="13">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Symbol" Value="ChevronUp24" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </ToggleButton.Content>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>

                    <!-- 详情区 -->
                    <StackPanel Margin="32,12,0,0"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">

                        <!-- 类型相关字段：builtin -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="builtin">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="内置实现" />
                            <ComboBox ItemsSource="{Binding DataContext.BuiltInChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding BuiltIn, UpdateSourceTrigger=PropertyChanged}"
                                      Width="280"
                                      HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- 类型相关字段：url-template -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="url-template">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="URL 模板" />
                            <ui:TextBox Text="{Binding UrlTemplate, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="https://example.com/search?q={q}" />
                            <TextBlock Style="{StaticResource Settings.HintText}"
                                       Margin="0,4,0,0"
                                       Text="占位符：{q} = UrlEncode 后的选区；{text} = 原始文本；{urlencoded} 等同 {q}" />
                        </StackPanel>

                        <!-- 类型相关字段：script -->
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="script">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="脚本路径" />
                                    <ui:TextBox Text="{Binding ScriptPath, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="C:\Tools\my.ps1" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="参数模板" />
                                    <ui:TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="{}{text}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource Settings.HintText}"
                                       Margin="0,4,0,0"
                                       Text="参数中 {text} 会被替换为选区文本；脚本通过 stdin 也可以接收文本（v2 支持）" />
                        </StackPanel>

                        <!-- 共用：图标键 + 触发正则 -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="图标键" />
                                <ui:TextBox Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="如 Copy / Search / Url（参见 IconKeyToGlyphConverter）" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="触发正则 (matchRegex)" />
                                <ui:TextBox Text="{Binding MatchRegex, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="留空则永远显示" />
                            </StackPanel>
                        </Grid>

                        <!-- 正则匹配测试 -->
                        <Border Background="{DynamicResource Settings.Card.SubtleBackground}"
                                BorderBrush="{DynamicResource Settings.Stroke}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Settings.Radius.Sm}"
                                Padding="10"
                                Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}"
                                               Text="测试文本（针对本动作）"
                                               Margin="0,0,0,4" />
                                    <ui:TextBox Text="{Binding RegexTestText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <ui:Badge Grid.Column="1"
                                          VerticalAlignment="Bottom"
                                          Appearance="Success"
                                          Padding="10,5">
                                    <TextBlock Text="{Binding RegexResult}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </ui:Badge>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏（ExtendsContentIntoTitleBar=True 时需要） -->
        <ui:TitleBar Grid.Row="0"
                     Title="ClipAura 设置"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="ClipboardPaste24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============================ 侧边栏 ============================ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Settings.Sidebar.Background}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="18,16,18,12">
                        <ui:TextBox x:Name="SettingsSearchBox"
                                    PlaceholderText="搜索设置..."
                                    Icon="{ui:SymbolIcon Search24}"
                                    TextChanged="OnSettingsSearchChanged"
                                    KeyDown="OnSettingsSearchKeyDown" />
                        <TextBlock x:Name="SearchHint"
                                   Style="{StaticResource Settings.HintText}"
                                   Margin="2,6,0,0" />
                    </StackPanel>

                    <ListBox x:Name="NavigationList"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="10,8,10,16"
                             ItemContainerStyle="{StaticResource Settings.NavItem}"
                             SelectionChanged="OnNavigationChanged">
                        <ListBoxItem Tag="General">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="通用" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Appearance">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Color24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="外观" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Actions">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Apps24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="动作" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Processes">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppFolder24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="进程过滤" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Search">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="搜索引擎" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Hotkeys">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="快捷键" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="AI">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bot24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="AI" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="About">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="关于" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ============================ 主面板 ============================ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="36,28,36,20">
                    <Grid>
                        <!-- ===================== 通用 ===================== -->
                        <StackPanel x:Name="GeneralPage">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="通用" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="基础行为：全屏抑制、文本长度阈值与触发策略" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="基础" />
                                    <ui:ToggleSwitch x:Name="FullScreenSuppress"
                                                     Content="全屏应用期间抑制弹出"
                                                     Margin="0,2,0,10" />
                                    <ui:ToggleSwitch x:Name="LaunchAtStartup"
                                                     Content="开机自启"
                                                     Margin="0,2,0,10" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="最短文本长度" />
                                            <ui:NumberBox x:Name="MinTextLengthBox" Width="160" HorizontalAlignment="Left"
                                                          Minimum="1" Maximum="100000" SmallChange="1" LargeChange="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="最长文本长度" />
                                            <ui:NumberBox x:Name="MaxTextLengthBox" Width="160" HorizontalAlignment="Left"
                                                          Minimum="1" Maximum="300000" SmallChange="100" LargeChange="1000" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="触发策略" />
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="弹出方式" Margin="0,0,0,6" />
                                    <ComboBox x:Name="PopupModeBox"
                                              Width="280" HorizontalAlignment="Left"
                                              SelectionChanged="OnPopupModeChanged">
                                        <ComboBoxItem Content="选中即弹" Tag="Immediate" />
                                        <ComboBoxItem Content="延迟弹出" Tag="Delayed" />
                                        <ComboBoxItem Content="悬停稳定后弹出" Tag="HoverStill" />
                                        <ComboBoxItem Content="按住修饰键时才弹" Tag="ModifierRequired" />
                                    </ComboBox>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="延迟时间 (ms)" />
                                            <ui:NumberBox x:Name="PopupDelayBox"
                                                          Minimum="0" Maximum="1500" SmallChange="50" LargeChange="200" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="悬停稳定 (ms)" />
                                            <ui:NumberBox x:Name="HoverDelayBox"
                                                          Minimum="0" Maximum="1500" SmallChange="50" LargeChange="200" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="修饰键" />
                                            <ComboBox x:Name="RequiredModifierBox">
                                                <ComboBoxItem Content="Alt" Tag="Alt" />
                                                <ComboBoxItem Content="Ctrl" Tag="Ctrl" />
                                                <ComboBoxItem Content="Shift" Tag="Shift" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="自动消失" />
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Text="选择哪些情况下浮动工具栏会自动隐藏。"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <ui:ToggleSwitch x:Name="DismissOnMouseLeaveBox"
                                                             Content="鼠标离开浮窗一段时间后" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnForegroundChangedBox"
                                                             Content="前台窗口切换时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnClickOutsideBox"
                                                             Content="在浮窗外部按下鼠标时" Margin="0,0,0,4" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <ui:ToggleSwitch x:Name="DismissOnEscapeKeyBox"
                                                             Content="按下 ESC 键时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnNewSelectionBox"
                                                             Content="出现新选区候选时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnActionInvokedBox"
                                                             Content="执行动作完成后" Margin="0,0,0,4" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="鼠标离开后延迟 (ms)" />
                                            <ui:NumberBox x:Name="DismissMouseLeaveDelayBox"
                                                          Width="180" HorizontalAlignment="Left"
                                                          Minimum="0" Maximum="5000" SmallChange="100" LargeChange="500" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 外观 ===================== -->
                        <StackPanel x:Name="AppearancePage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="外观" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="浮动工具栏的显示模式、主题与按钮风格" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="按钮显示" />
                                    <WrapPanel>
                                        <RadioButton x:Name="DisplayIconAndText" GroupName="DisplayMode" Content="图标 + 文字" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DisplayIconOnly" GroupName="DisplayMode" Content="仅图标" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DisplayTextOnly" GroupName="DisplayMode" Content="仅文字" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="颜色主题" Margin="0,18,0,10" />
                                    <WrapPanel>
                                        <RadioButton x:Name="ThemeAuto" GroupName="ThemeMode" Content="自动跟随系统" Margin="0,0,16,0" />
                                        <RadioButton x:Name="ThemeLight" GroupName="ThemeMode" Content="浅色" Margin="0,0,16,0" />
                                        <RadioButton x:Name="ThemeDark" GroupName="ThemeMode" Content="深色" />
                                    </WrapPanel>
                                    <ui:ToggleSwitch x:Name="FollowAccentColor"
                                                     Content="选中按钮跟随系统强调色" Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="按钮风格" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="圆角半径" />
                                            <ui:NumberBox x:Name="CornerRadiusBox"
                                                          Minimum="0" Maximum="18" SmallChange="1" LargeChange="3" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="按钮间距" />
                                            <ui:NumberBox x:Name="ButtonSpacingBox"
                                                          Minimum="0" Maximum="10" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="字号" />
                                            <ui:NumberBox x:Name="ToolbarFontSizeBox"
                                                          Minimum="10" Maximum="18" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="每行动作数" />
                                            <ui:NumberBox x:Name="MaxActionsPerRowBox"
                                                          Minimum="3" Maximum="12" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 动作 ===================== -->
                        <StackPanel x:Name="ActionsPage" Visibility="Collapsed">
                            <DockPanel Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Style="{StaticResource Settings.PageTitle}" Text="动作" />
                                    <TextBlock Style="{StaticResource Settings.PageDescription}"
                                               Text="工具栏中显示的动作清单。可拖拽排序、按类型切换字段，并通过正则按上下文显示" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Right">
                                    <ui:Button Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Add24}"
                                               Content="添加内置"
                                               Margin="0,0,8,0"
                                               Click="OnAddBuiltInAction" />
                                    <ui:Button Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Link24}"
                                               Content="添加 URL"
                                               Margin="0,0,8,0"
                                               Click="OnAddUrlAction" />
                                    <ui:Button Appearance="Primary"
                                               Icon="{ui:SymbolIcon Code24}"
                                               Content="添加脚本"
                                               Click="OnAddScriptAction" />
                                </StackPanel>
                            </DockPanel>

                            <Border Style="{StaticResource Settings.SubCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}"
                                               Text="公共测试文本"
                                               Margin="4,0,12,0" />
                                    <ui:TextBox Grid.Column="1" x:Name="ActionGlobalTestText"
                                                PlaceholderText="输入示例文本：每条动作会用它即时显示正则匹配结果"
                                                TextChanged="OnActionGlobalTestChanged" />
                                </Grid>
                            </Border>

                            <ItemsControl x:Name="ActionsList"
                                          ItemsSource="{Binding ActionItems}"
                                          ItemTemplate="{StaticResource ActionItemTemplate}"
                                          AllowDrop="True"
                                          PreviewMouseLeftButtonDown="OnActionDragStart"
                                          MouseMove="OnActionMouseMove"
                                          Drop="OnActionDrop"
                                          Margin="0,8,0,0" />
                        </StackPanel>

                        <!-- ===================== 进程过滤 ===================== -->
                        <StackPanel x:Name="ProcessesPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="进程过滤" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="按前台进程过滤是否弹出工具栏：黑名单 = 列出的进程不弹；白名单 = 仅列出的进程弹" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,12">
                                        <RadioButton x:Name="BlacklistRadio" Content="黑名单" Margin="0,0,16,0" />
                                        <RadioButton x:Name="WhitelistRadio" Content="白名单" />
                                    </WrapPanel>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0" x:Name="ProcessNameBox"
                                                    PlaceholderText="例如 chrome.exe" />
                                        <ui:Button Grid.Column="1" Appearance="Primary" Content="添加 / 更新" Margin="8,0,0,0" Click="OnAddOrUpdateProcess" />
                                        <ui:Button Grid.Column="2" Appearance="Secondary" Content="删除" Margin="8,0,0,0" Click="OnRemoveProcess" />
                                        <ui:Button Grid.Column="3" Appearance="Transparent" Icon="{ui:SymbolIcon ArrowClockwise24}" Content="刷新最近" Margin="8,0,0,0" Click="OnRefreshRecentProcesses" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Settings.Radius.Sm}">
                                            <ListBox x:Name="ProcessList"
                                                     ItemsSource="{Binding ProcessFilters}"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     SelectionChanged="OnProcessSelected"
                                                     MinHeight="260" />
                                        </Border>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="最近活动窗口"
                                                       Style="{StaticResource Settings.FieldLabel}"
                                                       Margin="0,0,0,6" />
                                            <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource Settings.Radius.Sm}">
                                                <ListBox x:Name="RecentProcessList"
                                                         DisplayMemberPath="Display"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         SelectionChanged="OnRecentProcessPicked"
                                                         MinHeight="260" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 搜索引擎 ===================== -->
                        <StackPanel x:Name="SearchPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="搜索引擎" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="工具栏「搜索」按钮使用的引擎；URL 中 {q} 会被替换为选中文本的 UrlEncode 结果" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="预设引擎" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,18">
                                        <RadioButton x:Name="SearchGoogle" GroupName="SearchEngine" Content="Google" Margin="0,0,16,0" Click="OnSearchPresetChanged" />
                                        <RadioButton x:Name="SearchBing" GroupName="SearchEngine" Content="Bing" Margin="0,0,16,0" Click="OnSearchPresetChanged" />
                                        <RadioButton x:Name="SearchBaidu" GroupName="SearchEngine" Content="百度" Margin="0,0,16,0" Click="OnSearchPresetChanged" />
                                        <RadioButton x:Name="SearchCustom" GroupName="SearchEngine" Content="自定义" />
                                    </WrapPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="名称" />
                                        <ui:TextBox Grid.Column="1" x:Name="SearchEngineName" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="URL 模板" />
                                        <ui:TextBox Grid.Column="1" x:Name="SearchUrlTemplate" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 快捷键 ===================== -->
                        <StackPanel x:Name="HotkeysPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="快捷键" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="全局快捷键。格式：Ctrl+Alt+P，支持 Ctrl / Alt / Shift / Win 修饰键" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="280" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="暂停 / 恢复" />
                                        <ui:TextBox Grid.Column="1" x:Name="PauseHotKeyBox" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="280" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="唤起工具栏" />
                                        <ui:TextBox Grid.Column="1" x:Name="ToolbarHotKeyBox" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== AI ===================== -->
                        <StackPanel x:Name="AIPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="AI" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="预留 AI 动作配置入口" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <ui:ToggleSwitch x:Name="AiEnabledBox"
                                                     Content="启用 AI 动作入口" IsEnabled="False" />
                                    <ui:InfoBar Title="规划中"
                                                Message="AI 配置入口已预留，后续将支持配置模型、API Key 与提示词模板"
                                                Severity="Informational"
                                                IsClosable="False"
                                                IsOpen="True"
                                                Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 关于 ===================== -->
                        <StackPanel x:Name="AboutPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="关于" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="版本信息与配置目录" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="56" Height="56"
                                                Background="{DynamicResource Settings.Accent}"
                                                CornerRadius="{StaticResource Settings.Radius.Md}"
                                                Margin="0,0,16,0">
                                            <TextBlock Text="C"
                                                       Foreground="White"
                                                       FontSize="32"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="ClipAura" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="Windows 选区动作工具"
                                                       Foreground="{DynamicResource Settings.SubtleForeground}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="配置目录" />
                                        <TextBlock Grid.Column="1" Text="%LOCALAPPDATA%\PopClip.Win"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- 底部 sticky 操作栏 -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Settings.Card.Background}"
                        BorderBrush="{DynamicResource Settings.Stroke}"
                        BorderThickness="0,1,0,0"
                        Padding="36,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button x:Name="CancelBtn"
                                   Appearance="Secondary"
                                   Content="取消"
                                   Width="100"
                                   Margin="0,0,10,0"
                                   Click="OnCancel" />
                        <ui:Button x:Name="OkBtn"
                                   Appearance="Primary"
                                   Content="保存"
                                   Width="100"
                                   Click="OnSave" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
