<ui:FluentWindow x:Class="PopClip.App.UI.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:PopClip.App.UI"
                 Title="ClipAura 设置"
                 Icon="pack://application:,,,/Assets/AppIcon.ico"
                 Width="1020" Height="820"
                 MinWidth="880" MinHeight="600"
                 ShowInTaskbar="True"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 Foreground="{DynamicResource Settings.Foreground}"
                 FontFamily="{DynamicResource Settings.FontFamily}"
                 UseLayoutRounding="True"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <local:IconKeyToMaterialDesignKindConverter x:Key="MaterialIconConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 每条 Action 卡片的 DataTemplate。
             去掉了"展开/折叠"和"类型下拉"：卡片在创建时就根据入口决定了 Type，
             所有可编辑字段平铺显示，仅根据 IconLocked / IsAiType / IsUrlType 做条件可见 -->
        <DataTemplate x:Key="ActionItemTemplate" DataType="{x:Type local:ActionEditorItem}">
            <Border Background="{DynamicResource Settings.Card.Background}"
                    BorderBrush="{DynamicResource Settings.Card.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="14,12,14,12"
                    Margin="0,0,0,8"
                    SnapsToDevicePixels="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- 主行：拖拽柄 + 图标 + 名称 + 输出模式 + 启用 + 操作按钮。
                         名称列 MinWidth=120/Width=* 保证最短能容纳常见动作名，多余空间分给名称；
                         输出模式下拉固定 160 宽，让其它列布局稳定 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="ReOrderDotsVertical24"
                                       FontSize="14"
                                       Foreground="{DynamicResource Settings.Muted}"
                                       VerticalAlignment="Center"
                                       Cursor="SizeAll"
                                       ToolTip="拖拽以重排" />

                        <!-- 图标区：锁定（系统语义图标）只显示预览 Border；可编辑（用户动作）显示 ComboBox。
                             宽度按 ComboBox 闭合态需要容纳的 "图标 + Label + 下拉箭头" 估算到 92px：
                             16(图标) + 8(间距) + 28(中文 Label 2 字) + 36(ComboBox padding + 箭头) ≈ 88 -->
                        <Grid Grid.Column="1" Width="92" Height="32" Margin="0,0,12,0">
                            <Border Background="{DynamicResource Settings.AccentSoft}"
                                    CornerRadius="{StaticResource Settings.Radius.Sm}"
                                    Width="32" Height="32"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding IconLocked, Converter={StaticResource BoolToVis}}"
                                    ToolTip="此动作的图标由系统语义决定，不可修改">
                                <iconPacks:PackIconMaterialDesign Kind="{Binding Icon, Converter={StaticResource MaterialIconConv}}"
                                                                  Width="17"
                                                                  Height="17"
                                                                  Foreground="{DynamicResource Settings.Accent}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center" />
                            </Border>
                            <ComboBox Height="32"
                                      HorizontalAlignment="Stretch"
                                      VerticalContentAlignment="Center"
                                      Padding="6,0,4,0"
                                      Visibility="{Binding IsIconEditable, Converter={StaticResource BoolToVis}}"
                                      ItemsSource="{Binding DataContext.IconChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValuePath="IconKey"
                                      SelectedValue="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="选择图标">
                                <!-- ItemTemplate 同时用于下拉列表项和闭合态 SelectedItem 渲染。
                                     这里 PackIcon 用 14 + 8 间距 + 自动伸缩 TextBlock，
                                     避免内置 SelectionBoxItemTemplate 限制（WPF 中只读，不能 XAML 配置） -->
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,4,0">
                                            <iconPacks:PackIconMaterialDesign Kind="{Binding IconKey, Converter={StaticResource MaterialIconConv}}"
                                                                              Width="14" Height="14"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <ui:TextBox Grid.Column="2"
                                    Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    PlaceholderText="动作名称" />

                        <!-- 内置 smart 动作的"结果输出方式"下拉。AI 动作的同名下拉在下方展开区域里，
                             所以这里只对 IsBuiltInOutputConfigurable=true 的动作显示 -->
                        <ComboBox Grid.Column="3"
                                  Width="160"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding DataContext.BuiltInOutputModeChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding OutputMode, UpdateSourceTrigger=PropertyChanged}"
                                  Visibility="{Binding IsBuiltInOutputConfigurable, Converter={StaticResource BoolToVis}}"
                                  ToolTip="结果输出方式：仅复制 / 气泡 / 复制+气泡 / 独立结果窗口" />

                        <ui:ToggleSwitch Grid.Column="4"
                                         IsChecked="{Binding Enabled}"
                                         VerticalAlignment="Center"
                                         Margin="12,0,8,0"
                                         ToolTip="启用此动作" />

                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon ArrowUp24}"
                                       Tag="{Binding}"
                                       Click="OnActionMoveUp"
                                       Padding="6"
                                       ToolTip="上移" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon ArrowDown24}"
                                       Tag="{Binding}"
                                       Click="OnActionMoveDown"
                                       Padding="6"
                                       Margin="2,0,0,0"
                                       ToolTip="下移" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Tag="{Binding}"
                                       Click="OnActionDelete"
                                       Padding="6"
                                       Margin="2,0,0,0"
                                       Foreground="{DynamicResource Settings.Danger}"
                                       ToolTip="删除" />
                        </StackPanel>
                    </Grid>

                    <!-- URL 模板字段：仅当 Type=url-template 时显示 -->
                    <StackPanel Margin="34,10,0,0"
                                Visibility="{Binding IsUrlType, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="URL 模板" />
                        <ui:TextBox Text="{Binding UrlTemplate, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="https://example.com/search?q={q}" />
                        <TextBlock Style="{StaticResource Settings.HintText}"
                                   Margin="0,4,0,0"
                                   Text="占位符：{q} = 选中文本（URL 编码后）；{text} = 原始选中文本" />
                    </StackPanel>

                    <!-- AI Prompt 字段：仅当 Type=ai 时显示 -->
                    <StackPanel Margin="34,10,0,0"
                                Visibility="{Binding IsAiType, Converter={StaticResource BoolToVis}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="结果展示方式" />
                                <ComboBox ItemsSource="{Binding DataContext.AiOutputModeChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding OutputMode, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="System Prompt（可选）" />
                                <ui:TextBox Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="留空使用 ClipAura 默认助手提示词" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Prompt 模板" />
                        <ui:TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    MaxHeight="220"
                                    VerticalScrollBarVisibility="Auto"
                                    PlaceholderText="例如：只输出修正语法后的{language}文本：&#x0a;&#x0a;{text}" />
                        <TextBlock Style="{StaticResource Settings.HintText}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Text="可用变量：{text} 选中文本，{language} 目标语言，{clipboard} 剪贴板内容。&#x0a;若 Prompt 中不含 {text}，运行时会自动把选中文本追加到末尾。" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏（ExtendsContentIntoTitleBar=True 时需要） -->
        <ui:TitleBar Grid.Row="0"
                     Title="ClipAura 设置"
                     Icon="{ui:ImageIcon 'pack://application:,,,/Assets/AppIcon.ico'}"
                     Style="{StaticResource Settings.CompactTitleBar}"
                     ShowMaximize="True"
                     ShowMinimize="True" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============================ 侧边栏 ============================ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Settings.Sidebar.Background}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="18,16,18,12">
                        <ui:TextBox x:Name="SettingsSearchBox"
                                    PlaceholderText="搜索设置..."
                                    Icon="{ui:SymbolIcon Search24}"
                                    TextChanged="OnSettingsSearchChanged"
                                    KeyDown="OnSettingsSearchKeyDown" />
                        <TextBlock x:Name="SearchHint"
                                   Style="{StaticResource Settings.HintText}"
                                   Margin="2,6,0,0" />
                    </StackPanel>

                    <ListBox x:Name="NavigationList"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="10,8,10,16"
                             ItemContainerStyle="{StaticResource Settings.NavItem}"
                             SelectionChanged="OnNavigationChanged">
                        <ListBoxItem Tag="General">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="通用" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Appearance">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Color24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="外观" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Actions">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Apps24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="动作" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Processes">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppFolder24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="进程过滤" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Search">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="搜索引擎" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Hotkeys">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="快捷键" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="AI">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bot24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="AI" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Templates">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Prompt 模板" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="History">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="History24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="对话历史" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Usage">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DataUsage24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="用量" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="About">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="关于" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ============================ 主面板 ============================
                 显式 Background 让标题/副标题等"非卡片"区域也跟随主题色，
                 避免 Mica 半透明导致深色主题下大片背景看不出色调 -->
            <Grid Grid.Column="1"
                  Background="{DynamicResource Settings.Window.Background}">
                <!-- 全部设置改为"点击即生效"，不再需要底部"保存/取消"按钮区。
                     左右 padding 缩到 24，缩短侧边栏与卡片之间的视觉间隙 -->
                <ScrollViewer x:Name="MainScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="24,20,24,20">
                    <Grid>
                        <!-- ===================== 通用 ===================== -->
                        <StackPanel x:Name="GeneralPage">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="通用" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="基础行为：全屏抑制、文本长度阈值与触发策略" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="基础" />
                                    <ui:ToggleSwitch x:Name="FullScreenSuppress"
                                                     Content="全屏应用期间抑制弹出"
                                                     Margin="0,2,0,10" />
                                    <ui:ToggleSwitch x:Name="LaunchAtStartup"
                                                     Content="开机自启"
                                                     Margin="0,2,0,10" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="最短文本长度" />
                                            <ui:NumberBox x:Name="MinTextLengthBox" Width="160" HorizontalAlignment="Left"
                                                          Minimum="1" Maximum="100000" SmallChange="1" LargeChange="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="最长文本长度" />
                                            <ui:NumberBox x:Name="MaxTextLengthBox" Width="160" HorizontalAlignment="Left"
                                                          Minimum="1" Maximum="300000" SmallChange="100" LargeChange="1000" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="触发策略" />
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="弹出方式" Margin="0,0,0,6" />
                                    <ComboBox x:Name="PopupModeBox"
                                              Width="280" HorizontalAlignment="Left"
                                              SelectionChanged="OnPopupModeChanged">
                                        <ComboBoxItem Content="选中即弹" Tag="Immediate" />
                                        <ComboBoxItem Content="延迟弹出" Tag="Delayed" />
                                        <ComboBoxItem Content="悬停稳定后弹出" Tag="HoverStill" />
                                        <ComboBoxItem Content="按住修饰键时才弹" Tag="ModifierRequired" />
                                    </ComboBox>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="延迟时间 (ms)" />
                                            <ui:NumberBox x:Name="PopupDelayBox"
                                                          Minimum="0" Maximum="1500" SmallChange="50" LargeChange="200" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="悬停稳定 (ms)" />
                                            <ui:NumberBox x:Name="HoverDelayBox"
                                                          Minimum="0" Maximum="1500" SmallChange="50" LargeChange="200" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="修饰键" />
                                            <ComboBox x:Name="RequiredModifierBox">
                                                <ComboBoxItem Content="Alt" Tag="Alt" />
                                                <ComboBoxItem Content="Ctrl" Tag="Ctrl" />
                                                <ComboBoxItem Content="Shift" Tag="Shift" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="快捷点击修饰键" />
                                        <ComboBox x:Name="QuickClickModifierBox"
                                                  Width="160"
                                                  HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Ctrl" Tag="Ctrl" />
                                            <ComboBoxItem Content="Alt" Tag="Alt" />
                                            <ComboBoxItem Content="Shift" Tag="Shift" />
                                        </ComboBox>
                                        <TextBlock Style="{StaticResource Settings.HintText}"
                                                   Margin="0,4,0,0"
                                                   Text="修饰键 + 左键点击时显示粘贴与剪贴板工具条。" />
                                    </StackPanel>

                                    <!-- 键盘选择默认全部不弹（避免干扰键盘流），唯一例外是 Ctrl+A
                                         因为全选是带明确意图的操作；此开关可让纯键盘用户彻底关掉 -->
                                    <ui:ToggleSwitch x:Name="EnableSelectAllPopupBox"
                                                     Content="Ctrl+A 全选时弹出浮窗"
                                                     Margin="0,16,0,0" />
                                    <ui:ToggleSwitch x:Name="EnableToolbarKeyboardShortcutsBox"
                                                     Content="浮窗开启键盘快捷操作"
                                                     Margin="0,8,0,0" />
                                    <Grid Margin="24,4,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=EnableToolbarKeyboardShortcutsBox}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:ToggleSwitch x:Name="EnableToolbarTabNavigationBox"
                                                         Content="Tab 切换按钮"
                                                         Margin="0,0,16,0" />
                                        <ui:ToggleSwitch x:Name="EnableToolbarNumberShortcutsBox"
                                                         Grid.Column="1"
                                                         Content="数字键 1/2/3 执行动作" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="自动消失" />
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Text="选择哪些情况下浮动工具栏会自动隐藏。"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <ui:ToggleSwitch x:Name="DismissOnForegroundChangedBox"
                                                             Content="前台窗口切换时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnClickOutsideBox"
                                                             Content="在浮窗外部按下鼠标时" Margin="0,0,0,4" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <ui:ToggleSwitch x:Name="DismissOnEscapeKeyBox"
                                                             Content="按下 ESC 键时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnNewSelectionBox"
                                                             Content="出现新选区候选时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnActionInvokedBox"
                                                             Content="执行动作完成后" Margin="0,0,0,4" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0">
                                        <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Settings.Radius.Sm}"
                                                Padding="12"
                                                Background="{DynamicResource Settings.Card.SubtleBackground}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:ToggleSwitch x:Name="DismissOnMouseLeaveBox"
                                                                 Content="鼠标离开浮窗后自动消失"
                                                                 VerticalAlignment="Center" />
                                                <ui:NumberBox x:Name="DismissMouseLeaveDelayBox"
                                                              Grid.Column="1"
                                                              Margin="12,0,0,0"
                                                              ClearButtonEnabled="False"
                                                              SpinButtonPlacementMode="Hidden"
                                                              Minimum="0" Maximum="5000" SmallChange="100" LargeChange="500" />
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource Settings.HintText}"
                                                           Text="ms" />
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                                BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Settings.Radius.Sm}"
                                                Padding="12"
                                                Background="{DynamicResource Settings.Card.SubtleBackground}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:ToggleSwitch x:Name="DismissOnTimeoutBox"
                                                                 Content="浮窗超时后自动消失"
                                                                 VerticalAlignment="Center" />
                                                <ui:NumberBox x:Name="DismissTimeoutMsBox"
                                                              Grid.Column="1"
                                                              Margin="12,0,0,0"
                                                              ClearButtonEnabled="False"
                                                              SpinButtonPlacementMode="Hidden"
                                                              Minimum="100" Maximum="120000" SmallChange="100" LargeChange="1000" />
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource Settings.HintText}"
                                                           Text="ms" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 外观 =====================
                             AppearancePage 改为 Grid：行 0 固定（页头 + 实时预览），行 1 内部 ScrollViewer 滚动其它卡片。
                             Height 绑定外层 ScrollViewer.ViewportHeight（内容区域高度，不含 Padding），
                             外观页恰好占满可视区域，避免外层产生多余滚动条 -->
                        <Grid x:Name="AppearancePage"
                              Visibility="Collapsed"
                              Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- 顶部固定区右侧 Margin 与下方 ScrollViewer 内 StackPanel 保持一致（14），
                                 让"预览卡片右边缘"与"按钮显示/字体等设置卡片右边缘"在视觉上严格对齐 -->
                            <StackPanel Grid.Row="0" Margin="0,0,14,0">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="外观" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="浮动工具栏的显示模式、主题与按钮风格。所有调整即时生效，下方主体可滚动浏览。" />

                            <!-- ============= 实时预览：与真实浮窗共用同一套 Toolbar* 主题资源与字体，
                                                外观页所有可视参数变化都在这里直接反映 ============= -->
                            <Border Margin="0,0,0,16"
                                    Padding="20,18,20,16"
                                    Background="{DynamicResource Settings.Card.SubtleBackground}"
                                    BorderBrush="{DynamicResource Settings.Stroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Settings.Radius.Md}"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               HorizontalAlignment="Left"
                                               Margin="0,0,0,10"
                                               Text="实时预览（与真实浮窗一致）" />
                                    <Border Background="{DynamicResource ToolbarBackground}"
                                            BorderBrush="{DynamicResource ToolbarBorder}"
                                            CornerRadius="{Binding PreviewCornerRadius}"
                                            BorderThickness="{Binding PreviewBorderThickness}"
                                            Opacity="{Binding PreviewOpacity}"
                                            HorizontalAlignment="Center"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000"
                                                              Direction="270"
                                                              ShadowDepth="{Binding PreviewShadowDepth}"
                                                              BlurRadius="{Binding PreviewShadowBlurRadius}"
                                                              Opacity="{Binding PreviewShadowOpacity}" />
                                        </Border.Effect>
                                        <ItemsControl ItemsSource="{Binding ToolbarPreviewItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent"
                                                            CornerRadius="{Binding DataContext.PreviewButtonCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Margin="{Binding DataContext.PreviewButtonMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Padding="{Binding DataContext.PreviewButtonPadding, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                            <ui:SymbolIcon Symbol="{Binding Icon}"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="{Binding DataContext.PreviewIconFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           Foreground="{DynamicResource ToolbarForeground}"
                                                                           Visibility="{Binding DataContext.PreviewIconVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            <TextBlock Text="{Binding Title}"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,2,0,0"
                                                                       FontFamily="{DynamicResource ToolbarFontFamily}"
                                                                       FontSize="{Binding DataContext.PreviewFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="{DynamicResource ToolbarForeground}"
                                                                       Visibility="{Binding DataContext.PreviewTextVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </Border>
                            </StackPanel>

                            <!-- 行 1：可滚动主体。所有外观设置卡片放进这里，鼠标滚轮在此区域才滚动。
                                 StackPanel 右边留 14 让滚动条悬浮在卡片右侧之外，
                                 避免拉到底部时滚动条与卡片底边相互穿插；
                                 Row 0 的预览卡片也用相同 Margin-Right 让上下卡片右边对齐 -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Padding="0,0,0,4">
                                <StackPanel Margin="0,0,14,0">
                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="按钮显示" />
                                    <WrapPanel>
                                        <RadioButton x:Name="DisplayIconAndText" GroupName="DisplayMode" Content="图标 + 文字" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DisplayIconOnly" GroupName="DisplayMode" Content="仅图标" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DisplayTextOnly" GroupName="DisplayMode" Content="仅文字" />
                                    </WrapPanel>

                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="颜色主题" Margin="0,18,0,10" />
                    <TextBlock Style="{StaticResource Settings.HintText}"
                               Margin="0,0,0,10"
                               Text="主题对全局生效：浮窗、设置窗口、对话窗等同步切换。基础三档可跟随系统明暗，彩色预设保留各自配色。" />
                    <!-- 主题预览卡片列表：选中后立即写入 settings.json 并刷新全局画刷 -->
                                    <ListBox x:Name="ThemePresetList"
                                             ItemsSource="{Binding ToolbarThemeChoices}"
                                             SelectedValuePath="Mode"
                                             SelectionMode="Single"
                                             SelectionChanged="OnToolbarThemeChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             KeyboardNavigation.DirectionalNavigation="Cycle">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" IsItemsHost="True" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="0,0,10,10" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd"
                                                                    Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                                    BorderBrush="{DynamicResource Settings.Stroke}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{StaticResource Settings.Radius.Md}"
                                                                    Padding="10,8,12,8"
                                                                    SnapsToDevicePixels="True">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Settings.Accent}" />
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Settings.Accent}" />
                                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Settings.AccentSoft}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- 颜色预览圆点：左主背景色 / 右前景色 -->
                                                    <Border Width="22" Height="22"
                                                            CornerRadius="11"
                                                            Background="{Binding BackgroundBrush}"
                                                            BorderBrush="{DynamicResource Settings.Stroke}"
                                                            BorderThickness="1"
                                                            VerticalAlignment="Center" />
                                                    <Border Width="22" Height="22"
                                                            CornerRadius="11"
                                                            Background="{Binding ForegroundBrush}"
                                                            BorderBrush="{DynamicResource Settings.Stroke}"
                                                            BorderThickness="1"
                                                            Margin="-8,0,8,0"
                                                            VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="{StaticResource Settings.FontSize.Body}"
                                                               Foreground="{DynamicResource Settings.Foreground}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <ui:ToggleSwitch x:Name="FollowAccentColor"
                                                     Content="选中按钮跟随系统强调色（仅基础三档生效）"
                                                     Margin="0,8,0,0" />

                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="浮窗外缘" Margin="0,18,0,10" />
                                    <WrapPanel>
                                        <RadioButton x:Name="SurfaceShadow" GroupName="SurfaceStyle" Content="强阴影" Margin="0,0,16,0" />
                                        <RadioButton x:Name="SurfaceBorder" GroupName="SurfaceStyle" Content="细边框" Margin="0,0,16,0" />
                                        <RadioButton x:Name="SurfaceShadowAndBorder" GroupName="SurfaceStyle" Content="阴影 + 细边框" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="字体" />
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Text="界面字体作用于设置窗口与对话窗等程序自身界面；浮窗字体仅作用于选区悬浮工具栏，留空则继承界面字体；两者都留空时使用应用内置的中文优先回退链（首选 Microsoft YaHei UI）。"
                                               Margin="0,0,0,12" />
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Style="{StaticResource Settings.FieldLabel}"
                                                   Text="界面字体" />
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  x:Name="UiFontFamilyBox"
                                                  IsEditable="True"
                                                  StaysOpenOnEdit="True"
                                                  MaxDropDownHeight="320"
                                                  SelectionChanged="OnUiFontFamilyChanged"
                                                  LostFocus="OnUiFontFamilyChanged" />
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   x:Name="UiFontPreview"
                                                   Margin="12,0,0,0"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="界面字体预览 AaBb 1234" />

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource Settings.FieldLabel}"
                                                   Text="浮窗字体" />
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  Margin="0,10,0,0"
                                                  x:Name="ToolbarFontFamilyBox"
                                                  IsEditable="True"
                                                  StaysOpenOnEdit="True"
                                                  MaxDropDownHeight="320"
                                                  SelectionChanged="OnToolbarFontFamilyChanged"
                                                  LostFocus="OnToolbarFontFamilyChanged" />
                                        <TextBlock Grid.Row="1" Grid.Column="2"
                                                   x:Name="ToolbarFontPreview"
                                                   Margin="12,10,0,0"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="浮窗字体预览 AaBb 1234" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <ui:Button Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon ArrowReset24}"
                                                   Content="重置为默认"
                                                   Click="OnResetFontFamilies" />
                                        <TextBlock Style="{StaticResource Settings.HintText}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="可直接输入字体名（支持英文/中文族名），例如 JetBrains Mono、霞鹜文楷、思源宋体。" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="按钮风格" />
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}"
                                               Text="密度"
                                               Margin="0,0,0,4" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <RadioButton x:Name="DensityCompact" GroupName="ToolbarDensity" Content="紧凑" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DensityStandard" GroupName="ToolbarDensity" Content="标准" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DensityComfortable" GroupName="ToolbarDensity" Content="宽松" />
                                    </WrapPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="圆角半径" />
                                            <ui:NumberBox x:Name="CornerRadiusBox"
                                                          Minimum="0" Maximum="18" SmallChange="1" LargeChange="3" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="按钮间距" />
                                            <ui:NumberBox x:Name="ButtonSpacingBox"
                                                          Minimum="0" Maximum="10" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="字号" />
                                            <ui:NumberBox x:Name="ToolbarFontSizeBox"
                                                          Minimum="10" Maximum="18" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="每行动作数" />
                                            <ui:NumberBox x:Name="MaxActionsPerRowBox"
                                                          Minimum="3" Maximum="12" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Style="{StaticResource Settings.FieldLabel}"
                                               Text="分行布局"
                                               Margin="0,14,0,4" />
                                    <WrapPanel>
                                        <RadioButton x:Name="ToolbarLayoutSingle"
                                                     GroupName="ToolbarLayout"
                                                     Content="默认（按配置顺序单行）"
                                                     Margin="0,0,16,0" />
                                        <RadioButton x:Name="ToolbarLayoutSmartRow"
                                                     GroupName="ToolbarLayout"
                                                     Content="智能动作单独一行"
                                                     Margin="0,0,16,0" />
                                        <RadioButton x:Name="ToolbarLayoutGroupRows"
                                                     GroupName="ToolbarLayout"
                                                     Content="按分组多行（基础 / 智能 / AI）" />
                                    </WrapPanel>
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Margin="0,4,0,0"
                                               Text="多行模式仅在当前选区同时出现 ≥ 2 组动作时才换行；只有一类时仍紧凑单行。" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="透明度" />
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Text="鼠标未悬停时浮窗的不透明度；鼠标进入浮窗后会自动恢复为完全不透明，便于点击。"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="ToolbarOpacitySlider"
                                                Grid.Column="0"
                                                Minimum="0.3"
                                                Maximum="1.0"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="False"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0"
                                                ValueChanged="OnToolbarOpacityChanged" />
                                        <TextBlock x:Name="ToolbarOpacityValue"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource Settings.SubtleForeground}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- ===================== 动作 ===================== -->
                        <!-- Height 绑定 ViewportHeight（外层 ScrollViewer 的可视区域内高度），
                             与 AppearancePage 一致：ActualHeight 包含 ScrollViewer 自身边框，
                             会让 ActionsPage 比 viewport 略大几像素，触发外层多余的滚动条 -->
                        <Grid x:Name="ActionsPage"
                              Visibility="Collapsed"
                              Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="240" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource Settings.PageTitle}" Text="动作" />
                                    <TextBlock Style="{StaticResource Settings.PageDescription}"
                                               Text="选中文字后浮窗里显示的按钮。可拖拽调整顺序，开关右侧切换是否启用。"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Right">
                                    <ui:Button Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Add24}"
                                               Content="添加内置动作"
                                               Margin="0,0,6,0"
                                               ToolTip="基础 / 智能 / AI 内置动作，每种只能添加一次"
                                               Click="OnAddBuiltInAction" />
                                    <ui:Button Appearance="Primary"
                                               Icon="{ui:SymbolIcon Sparkle24}"
                                               Content="添加用户动作"
                                               ToolTip="自定义 URL / AI Prompt 动作，可重复添加"
                                               Click="OnAddUserAction" />
                                </StackPanel>
                            </Grid>

                            <!-- 模板速搭已迁移到"添加用户动作"对话框，避免与内置 AI 动作（如 AI 解释）产生重复语义。
                                 这里保留一个仅用于占位的隐藏 ItemsControl，让以前依赖该绑定的代码路径不报空引用 -->
                            <Border Grid.Row="1" Style="{StaticResource Settings.SubCard}" Margin="0,0,0,12"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding BuiltinPromptTemplates}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Tag="{Binding}"
                                                        Click="OnAddFromTemplate"
                                                        Margin="0,0,6,6"
                                                        Padding="10,4"
                                                        Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                        BorderBrush="{DynamicResource Settings.Stroke}"
                                                        BorderThickness="1"
                                                        Foreground="{DynamicResource Settings.SubtleForeground}"
                                                        FontSize="12"
                                                        ToolTip="{Binding Description}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="11"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="＋" Margin="0,0,4,0" Opacity="0.7" />
                                                                    <TextBlock Text="{Binding Title}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Margin="0,8,0,0"
                                          CanContentScroll="False">
                                <ItemsControl x:Name="ActionsList"
                                              ItemsSource="{Binding ActionItems}"
                                              ItemTemplate="{StaticResource ActionItemTemplate}"
                                              AllowDrop="True"
                                              PreviewMouseLeftButtonDown="OnActionDragStart"
                                              MouseMove="OnActionMouseMove"
                                              Drop="OnActionDrop" />
                            </ScrollViewer>
                        </Grid>

                        <!-- ===================== 进程过滤 ===================== -->
                        <StackPanel x:Name="ProcessesPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="进程过滤" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="按前台进程过滤是否弹出工具栏：黑名单 = 列出的进程不弹；白名单 = 仅列出的进程弹" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,12">
                                        <RadioButton x:Name="BlacklistRadio" Content="黑名单" Margin="0,0,16,0" />
                                        <RadioButton x:Name="WhitelistRadio" Content="白名单" />
                                    </WrapPanel>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0" x:Name="ProcessNameBox"
                                                    PlaceholderText="例如 chrome.exe" />
                                        <ui:Button Grid.Column="1" Appearance="Primary" Content="添加 / 更新" Margin="8,0,0,0" Click="OnAddOrUpdateProcess" />
                                        <ui:Button Grid.Column="2" Appearance="Secondary" Content="删除" Margin="8,0,0,0" Click="OnRemoveProcess" />
                                        <ui:Button Grid.Column="3" Appearance="Transparent" Icon="{ui:SymbolIcon ArrowClockwise24}" Content="刷新最近" Margin="8,0,0,0" Click="OnRefreshRecentProcesses" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="过滤名单"
                                                       Style="{StaticResource Settings.FieldLabel}"
                                                       Margin="0,0,0,6" />
                                            <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                                    BorderThickness="1"
