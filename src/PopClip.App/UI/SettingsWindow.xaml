                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding DateLabel}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Settings.Foreground}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding CallsLabel}"
                                                               Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding PromptLabel}"
                                                               Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding CompletionLabel}"
                                                               Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 关于 ===================== -->
                        <StackPanel x:Name="AboutPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="关于" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="应用状态、日志记录与本地目录" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="56" Height="56"
                                                Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
