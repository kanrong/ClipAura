                                    <TextBlock x:Name="OcrProviderDetailText"
                                               Style="{StaticResource Settings.HintText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== AI ===================== -->
                        <StackPanel x:Name="AIPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="AI" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="选择模型服务并启用 AI 文本动作。选中文本会发送到当前配置的服务商。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <ui:ToggleSwitch x:Name="AiEnabledBox"
                                                     Content="启用 AI 动作入口" />

                                    <Grid Margin="0,16,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="Provider" />
                                        <ComboBox Grid.Column="1"
                                                  x:Name="AiProviderBox"
                                                  SelectionChanged="OnAiProviderChanged" />
                                        <TextBlock Grid.Column="2"
                                                   x:Name="AiProviderDescription"
                                                   Style="{StaticResource Settings.HintText}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="Base URL" />
                                        <ui:TextBox Grid.Column="1" x:Name="AiBaseUrlBox" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="Model" />
                                        <ui:TextBox Grid.Column="1" x:Name="AiModelBox" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="API Key" />
                                        <StackPanel Grid.Column="1">
                                            <PasswordBox x:Name="AiApiKeyBox" />
                                            <TextBlock x:Name="AiKeyStatus"
                                                       Style="{StaticResource Settings.HintText}"
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="超时 (秒)" />
                                        <ui:NumberBox Grid.Column="1"
                                                      x:Name="AiTimeoutBox"
                                                      Minimum="5"
                                                      Maximum="180"
                                                      SmallChange="5"
                                                      LargeChange="15" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource Settings.FieldLabel}" Text="默认输出语言" />
                                        <ui:TextBox Grid.Column="4" x:Name="AiDefaultLanguageBox" />
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="思考模式" />
                                        <ComboBox Grid.Column="1"
                                                  x:Name="AiThinkingModeBox" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource Settings.HintText}"
                                                   Text="自动保留服务商默认；快速降低延迟；深度优先推理质量。"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="单次最大输出 tokens" />
                                        <ui:NumberBox Grid.Column="1"
                                                      x:Name="AiMaxOutputTokensBox"
                                                      Minimum="0"
                                                      Maximum="262144"
                                                      SmallChange="512"
                                                      LargeChange="4096" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource Settings.HintText}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   Text="0=自动（快速 4K / 自动 16K / 深度 32K）。思考模型 reasoning 与正文共用此额度，过低会导致只输出思考过程。" />
                                    </Grid>

                                    <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,4,0,12"
                                            Padding="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Settings.SectionTitle}"
                                                       Text="AI 浮窗体验"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Style="{StaticResource Settings.HintText}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,10"
                                                       Text="以下开关仅在 AI 已启用并配置 API Key 时生效；未启用 AI 时永远走网页翻译且解释按钮不出现。" />
                                            <ui:ToggleSwitch x:Name="TranslateInlineBox"
                                                             Content="启用 AI 后，翻译使用内联气泡（关闭则始终打开网页翻译）"
                                                             Margin="0,0,0,8" />
                                            <ui:ToggleSwitch x:Name="ExplainEnabledBox"
                                                             Content="启用浮窗 AI 解释按钮（仅在 AI 已配置时显示）" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <ui:Button Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon PlugConnected24}"
                                                   Content="测试连接"
                                                   Click="OnAiTestConnection" />
                                    </StackPanel>

                                    <ui:InfoBar x:Name="AiTestInfo"
                                                Title="连接状态"
                                                Message=""
                                                Severity="Informational"
                                                IsClosable="False"
                                                IsOpen="False"
                                                Margin="0,12,0,0" />

                                    <ui:InfoBar Title="隐私提示"
                                                Message="启用后，AI 动作会把选中的文本发送到当前 Provider。API Key 将使用 Windows 当前用户加密保存。"
                                                Severity="Informational"
                                                IsClosable="False"
                                                IsOpen="True"
                                                Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== Prompt 模板 ===================== -->
                        <StackPanel x:Name="TemplatesPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="Prompt 模板" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="内置的高质量 Prompt 模板。点击右侧按钮即可一键提升为浮窗动作。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="内置模板" />
                                    <ItemsControl ItemsSource="{Binding BuiltinPromptTemplates}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                        BorderBrush="{DynamicResource Settings.Stroke}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource Settings.Radius.Md}"
                                                        Padding="14"
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource Settings.Foreground}" />
                                                                <Border Margin="8,0,0,0"
                                                                        Background="{DynamicResource Settings.AccentSoft}"
                                                                        CornerRadius="8"
                                                                        Padding="6,1"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding OutputMode}"
                                                                               FontSize="10.5"
                                                                               Foreground="{DynamicResource Settings.Accent}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}"
                                                                       Margin="0,4,0,4"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource Settings.SubtleForeground}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Prompt}"
                                                                       FontSize="11.5"
                                                                       Foreground="{DynamicResource Settings.Muted}"
                                                                       TextWrapping="Wrap"
                                                                       MaxHeight="60"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <ui:Button Grid.Column="1"
                                                                   VerticalAlignment="Top"
                                                                   Appearance="Primary"
                                                                   Icon="{ui:SymbolIcon Add24}"
                                                                   Content="加为动作"
                                                                   Tag="{Binding}"
                                                                   Click="OnAddFromTemplate" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 对话历史 ===================== -->
                        <StackPanel x:Name="HistoryPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="对话历史" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="最近的 AI 对话。点击条目可重新打开窗口继续追问。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0"
                                                    x:Name="HistorySearchBox"
                                                    PlaceholderText="搜索标题 / 引用文本 / 消息正文"
                                                    Icon="{ui:SymbolIcon Search24}"
                                                    TextChanged="OnHistorySearchChanged" />
                                        <ui:Button Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                                   Content="刷新"
                                                   Click="OnHistoryRefresh" />
                                    </Grid>
                                    <ListBox x:Name="HistoryListBox"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MaxHeight="420"
                                             MouseDoubleClick="OnHistoryDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource Settings.Foreground}" />
                                                        <TextBlock Text="{Binding MetaText}"
                                                                   FontSize="11.5"
                                                                   Foreground="{DynamicResource Settings.Muted}"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1"
                                                               Appearance="Transparent"
                                                               Icon="{ui:SymbolIcon Delete24}"
                                                               Tag="{Binding Id}"
                                                               Click="OnHistoryDeleteClicked"
                                                               Foreground="{DynamicResource Settings.Danger}"
                                                               ToolTip="删除此对话" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 用量 ===================== -->
                        <StackPanel x:Name="UsagePage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="AI 用量" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="每次 AI 调用都会按日聚合到本地数据库，不上传外部服务。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="累计" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="UsageTotalCalls" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="次调用" FontSize="11.5"
                                                       Foreground="{DynamicResource Settings.Muted}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="UsageTotalPrompt" FontSize="22" FontWeight="SemiBold"
