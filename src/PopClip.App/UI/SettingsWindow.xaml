<ui:FluentWindow x:Class="PopClip.App.UI.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:PopClip.App.UI"
                 Title="ClipAura 设置"
                 Icon="pack://application:,,,/Assets/AppIcon.ico"
                 Width="1020" Height="820"
                 MinWidth="880" MinHeight="600"
                 ShowInTaskbar="True"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 FontFamily="{StaticResource Settings.FontFamily}"
                 UseLayoutRounding="True"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <local:IconKeyToGlyphConverter x:Key="IconConv" />
        <local:IconKeyToFontFamilyConverter x:Key="IconFontConv" />
        <local:IconKeyToMaterialDesignKindConverter x:Key="MaterialIconConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 每条 Action 卡片的 DataTemplate。
             去掉了"展开/折叠"和"类型下拉"：卡片在创建时就根据入口决定了 Type，
             所有可编辑字段平铺显示，仅根据 IconLocked / IsAiType / IsUrlType 做条件可见 -->
        <DataTemplate x:Key="ActionItemTemplate" DataType="{x:Type local:ActionEditorItem}">
            <Border Background="{DynamicResource Settings.Card.Background}"
                    BorderBrush="{DynamicResource Settings.Card.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Settings.Radius.Md}"
                    Padding="14,12,14,12"
                    Margin="0,0,0,8"
                    SnapsToDevicePixels="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- 主行：拖拽柄 + 图标 + 名称 + 启用 + 操作按钮 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="ReOrderDotsVertical24"
                                       FontSize="14"
                                       Foreground="{DynamicResource Settings.Muted}"
                                       VerticalAlignment="Center"
                                       Cursor="SizeAll"
                                       ToolTip="拖拽以重排" />

                        <!-- 图标区：锁定时只显示预览，未锁定时显示带预览的下拉 -->
                        <Grid Grid.Column="1" Width="40" Height="32" Margin="0,0,12,0">
                            <Border Background="{DynamicResource Settings.AccentSoft}"
                                    CornerRadius="{StaticResource Settings.Radius.Sm}"
                                    Width="32" Height="32"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding IconLocked, Converter={StaticResource BoolToVis}}"
                                    ToolTip="此动作的图标由系统语义决定，不可修改">
                                <iconPacks:PackIconMaterialDesign Kind="{Binding Icon, Converter={StaticResource MaterialIconConv}}"
                                                                  Width="17"
                                                                  Height="17"
                                                                  Foreground="{DynamicResource Settings.Accent}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center" />
                            </Border>
                            <ComboBox Width="56" Height="32"
                                      HorizontalAlignment="Left"
                                      VerticalContentAlignment="Center"
                                      Visibility="{Binding IsIconEditable, Converter={StaticResource BoolToVis}}"
                                      ItemsSource="{Binding DataContext.IconChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValuePath="IconKey"
                                      SelectedValue="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="选择图标">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterialDesign Kind="{Binding IconKey, Converter={StaticResource MaterialIconConv}}"
                                                                              Width="14" Height="14"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <ui:TextBox Grid.Column="2"
                                    Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    PlaceholderText="动作名称" />

                        <ui:ToggleSwitch Grid.Column="3"
                                         IsChecked="{Binding Enabled}"
                                         VerticalAlignment="Center"
                                         Margin="12,0,8,0"
                                         ToolTip="启用此动作" />

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon ArrowUp24}"
                                       Tag="{Binding}"
                                       Click="OnActionMoveUp"
                                       Padding="6"
                                       ToolTip="上移" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon ArrowDown24}"
                                       Tag="{Binding}"
                                       Click="OnActionMoveDown"
                                       Padding="6"
                                       Margin="2,0,0,0"
                                       ToolTip="下移" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Tag="{Binding}"
                                       Click="OnActionDelete"
                                       Padding="6"
                                       Margin="2,0,0,0"
                                       Foreground="{DynamicResource Settings.Danger}"
                                       ToolTip="删除" />
                        </StackPanel>
                    </Grid>

                    <!-- URL 模板字段：仅当 Type=url-template 时显示 -->
                    <StackPanel Margin="34,10,0,0"
                                Visibility="{Binding IsUrlType, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="URL 模板" />
                        <ui:TextBox Text="{Binding UrlTemplate, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="https://example.com/search?q={q}" />
                        <TextBlock Style="{StaticResource Settings.HintText}"
                                   Margin="0,4,0,0"
                                   Text="占位符：{q} = 选中文本（URL 编码后）；{text} = 原始选中文本" />
                    </StackPanel>

                    <!-- AI Prompt 字段：仅当 Type=ai 时显示 -->
                    <StackPanel Margin="34,10,0,0"
                                Visibility="{Binding IsAiType, Converter={StaticResource BoolToVis}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="结果展示方式" />
                                <ComboBox ItemsSource="{Binding DataContext.AiOutputModeChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding OutputMode, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="System Prompt（可选）" />
                                <ui:TextBox Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="留空使用 ClipAura 默认助手提示词" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Prompt 模板" />
                        <ui:TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    MaxHeight="220"
                                    VerticalScrollBarVisibility="Auto"
                                    PlaceholderText="例如：只输出修正语法后的{language}文本：&#x0a;&#x0a;{text}" />
                        <TextBlock Style="{StaticResource Settings.HintText}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Text="可用变量：{text} 选中文本，{language} 目标语言，{clipboard} 剪贴板内容。&#x0a;若 Prompt 中不含 {text}，运行时会自动把选中文本追加到末尾。" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏（ExtendsContentIntoTitleBar=True 时需要） -->
        <ui:TitleBar Grid.Row="0"
                     Title="ClipAura 设置"
                     Icon="{ui:ImageIcon 'pack://application:,,,/Assets/AppIcon.ico'}"
                     Style="{StaticResource Settings.CompactTitleBar}"
                     ShowMaximize="True"
                     ShowMinimize="True" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============================ 侧边栏 ============================ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Settings.Sidebar.Background}"
                    BorderBrush="{DynamicResource Settings.Stroke}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="18,16,18,12">
                        <ui:TextBox x:Name="SettingsSearchBox"
                                    PlaceholderText="搜索设置..."
                                    Icon="{ui:SymbolIcon Search24}"
                                    TextChanged="OnSettingsSearchChanged"
                                    KeyDown="OnSettingsSearchKeyDown" />
                        <TextBlock x:Name="SearchHint"
                                   Style="{StaticResource Settings.HintText}"
                                   Margin="2,6,0,0" />
                    </StackPanel>

                    <ListBox x:Name="NavigationList"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="10,8,10,16"
                             ItemContainerStyle="{StaticResource Settings.NavItem}"
                             SelectionChanged="OnNavigationChanged">
                        <ListBoxItem Tag="General">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="通用" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Appearance">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Color24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="外观" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Actions">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Apps24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="动作" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Processes">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppFolder24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="进程过滤" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Search">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="搜索引擎" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Hotkeys">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="快捷键" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="AI">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bot24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="AI" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Templates">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Prompt 模板" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="History">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="History24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="对话历史" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="Usage">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DataUsage24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="用量" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="About">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" FontSize="14" Width="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="关于" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ============================ 主面板 ============================ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="36,28,36,20">
                    <Grid>
                        <!-- ===================== 通用 ===================== -->
                        <StackPanel x:Name="GeneralPage">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="通用" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="基础行为：全屏抑制、文本长度阈值与触发策略" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="基础" />
                                    <ui:ToggleSwitch x:Name="FullScreenSuppress"
                                                     Content="全屏应用期间抑制弹出"
                                                     Margin="0,2,0,10" />
                                    <ui:ToggleSwitch x:Name="LaunchAtStartup"
                                                     Content="开机自启"
                                                     Margin="0,2,0,10" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="最短文本长度" />
                                            <ui:NumberBox x:Name="MinTextLengthBox" Width="160" HorizontalAlignment="Left"
                                                          Minimum="1" Maximum="100000" SmallChange="1" LargeChange="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="最长文本长度" />
                                            <ui:NumberBox x:Name="MaxTextLengthBox" Width="160" HorizontalAlignment="Left"
                                                          Minimum="1" Maximum="300000" SmallChange="100" LargeChange="1000" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="触发策略" />
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="弹出方式" Margin="0,0,0,6" />
                                    <ComboBox x:Name="PopupModeBox"
                                              Width="280" HorizontalAlignment="Left"
                                              SelectionChanged="OnPopupModeChanged">
                                        <ComboBoxItem Content="选中即弹" Tag="Immediate" />
                                        <ComboBoxItem Content="延迟弹出" Tag="Delayed" />
                                        <ComboBoxItem Content="悬停稳定后弹出" Tag="HoverStill" />
                                        <ComboBoxItem Content="按住修饰键时才弹" Tag="ModifierRequired" />
                                    </ComboBox>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="延迟时间 (ms)" />
                                            <ui:NumberBox x:Name="PopupDelayBox"
                                                          Minimum="0" Maximum="1500" SmallChange="50" LargeChange="200" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="悬停稳定 (ms)" />
                                            <ui:NumberBox x:Name="HoverDelayBox"
                                                          Minimum="0" Maximum="1500" SmallChange="50" LargeChange="200" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="修饰键" />
                                            <ComboBox x:Name="RequiredModifierBox">
                                                <ComboBoxItem Content="Alt" Tag="Alt" />
                                                <ComboBoxItem Content="Ctrl" Tag="Ctrl" />
                                                <ComboBoxItem Content="Shift" Tag="Shift" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="快捷点击修饰键" />
                                        <ComboBox x:Name="QuickClickModifierBox"
                                                  Width="160"
                                                  HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Ctrl" Tag="Ctrl" />
                                            <ComboBoxItem Content="Alt" Tag="Alt" />
                                            <ComboBoxItem Content="Shift" Tag="Shift" />
                                        </ComboBox>
                                        <TextBlock Style="{StaticResource Settings.HintText}"
                                                   Margin="0,4,0,0"
                                                   Text="修饰键 + 左键点击时显示粘贴与剪贴板工具条。" />
                                    </StackPanel>

                                    <!-- 键盘选择默认全部不弹（避免干扰键盘流），唯一例外是 Ctrl+A
                                         因为全选是带明确意图的操作；此开关可让纯键盘用户彻底关掉 -->
                                    <ui:ToggleSwitch x:Name="EnableSelectAllPopupBox"
                                                     Content="Ctrl+A 全选时弹出浮窗"
                                                     Margin="0,16,0,0" />
                                    <ui:ToggleSwitch x:Name="EnableToolbarKeyboardShortcutsBox"
                                                     Content="浮窗开启键盘快捷操作"
                                                     Margin="0,8,0,0" />
                                    <Grid Margin="24,4,0,0"
                                          IsEnabled="{Binding IsChecked, ElementName=EnableToolbarKeyboardShortcutsBox}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:ToggleSwitch x:Name="EnableToolbarTabNavigationBox"
                                                         Content="Tab 切换按钮"
                                                         Margin="0,0,16,0" />
                                        <ui:ToggleSwitch x:Name="EnableToolbarNumberShortcutsBox"
                                                         Grid.Column="1"
                                                         Content="数字键 1/2/3 执行动作" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="自动消失" />
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Text="选择哪些情况下浮动工具栏会自动隐藏。"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <ui:ToggleSwitch x:Name="DismissOnForegroundChangedBox"
                                                             Content="前台窗口切换时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnClickOutsideBox"
                                                             Content="在浮窗外部按下鼠标时" Margin="0,0,0,4" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <ui:ToggleSwitch x:Name="DismissOnEscapeKeyBox"
                                                             Content="按下 ESC 键时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnNewSelectionBox"
                                                             Content="出现新选区候选时" Margin="0,0,0,4" />
                                            <ui:ToggleSwitch x:Name="DismissOnActionInvokedBox"
                                                             Content="执行动作完成后" Margin="0,0,0,4" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0">
                                        <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Settings.Radius.Sm}"
                                                Padding="12"
                                                Background="{DynamicResource Settings.Card.SubtleBackground}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:ToggleSwitch x:Name="DismissOnMouseLeaveBox"
                                                                 Content="鼠标离开浮窗后自动消失"
                                                                 VerticalAlignment="Center" />
                                                <ui:NumberBox x:Name="DismissMouseLeaveDelayBox"
                                                              Grid.Column="1"
                                                              Margin="12,0,0,0"
                                                              ClearButtonEnabled="False"
                                                              SpinButtonPlacementMode="Hidden"
                                                              Minimum="0" Maximum="5000" SmallChange="100" LargeChange="500" />
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource Settings.HintText}"
                                                           Text="ms" />
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                                BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Settings.Radius.Sm}"
                                                Padding="12"
                                                Background="{DynamicResource Settings.Card.SubtleBackground}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:ToggleSwitch x:Name="DismissOnTimeoutBox"
                                                                 Content="浮窗超时后自动消失"
                                                                 VerticalAlignment="Center" />
                                                <ui:NumberBox x:Name="DismissTimeoutMsBox"
                                                              Grid.Column="1"
                                                              Margin="12,0,0,0"
                                                              ClearButtonEnabled="False"
                                                              SpinButtonPlacementMode="Hidden"
                                                              Minimum="100" Maximum="120000" SmallChange="100" LargeChange="1000" />
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource Settings.HintText}"
                                                           Text="ms" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 外观 ===================== -->
                        <StackPanel x:Name="AppearancePage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="外观" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="浮动工具栏的显示模式、主题与按钮风格" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="按钮显示" />
                                    <WrapPanel>
                                        <RadioButton x:Name="DisplayIconAndText" GroupName="DisplayMode" Content="图标 + 文字" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DisplayIconOnly" GroupName="DisplayMode" Content="仅图标" Margin="0,0,16,0" />
                                        <RadioButton x:Name="DisplayTextOnly" GroupName="DisplayMode" Content="仅文字" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="颜色主题" Margin="0,18,0,10" />
                                    <WrapPanel>
                                        <RadioButton x:Name="ThemeAuto" GroupName="ThemeMode" Content="自动跟随系统" Margin="0,0,16,0" />
                                        <RadioButton x:Name="ThemeLight" GroupName="ThemeMode" Content="浅色" Margin="0,0,16,0" />
                                        <RadioButton x:Name="ThemeDark" GroupName="ThemeMode" Content="深色" />
                                    </WrapPanel>
                                    <ui:ToggleSwitch x:Name="FollowAccentColor"
                                                     Content="选中按钮跟随系统强调色" Margin="0,12,0,0" />

                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="浮窗外缘" Margin="0,18,0,10" />
                                    <WrapPanel>
                                        <RadioButton x:Name="SurfaceShadow" GroupName="SurfaceStyle" Content="强阴影" Margin="0,0,16,0" />
                                        <RadioButton x:Name="SurfaceBorder" GroupName="SurfaceStyle" Content="细边框" Margin="0,0,16,0" />
                                        <RadioButton x:Name="SurfaceShadowAndBorder" GroupName="SurfaceStyle" Content="阴影 + 细边框" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="按钮风格" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="圆角半径" />
                                            <ui:NumberBox x:Name="CornerRadiusBox"
                                                          Minimum="0" Maximum="18" SmallChange="1" LargeChange="3" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="按钮间距" />
                                            <ui:NumberBox x:Name="ButtonSpacingBox"
                                                          Minimum="0" Maximum="10" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="字号" />
                                            <ui:NumberBox x:Name="ToolbarFontSizeBox"
                                                          Minimum="10" Maximum="18" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="每行动作数" />
                                            <ui:NumberBox x:Name="MaxActionsPerRowBox"
                                                          Minimum="3" Maximum="12" SmallChange="1" LargeChange="2" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="透明度" />
                                    <TextBlock Style="{StaticResource Settings.HintText}"
                                               Text="鼠标未悬停时浮窗的不透明度；鼠标进入浮窗后会自动恢复为完全不透明，便于点击。"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="ToolbarOpacitySlider"
                                                Grid.Column="0"
                                                Minimum="0.3"
                                                Maximum="1.0"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="False"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0"
                                                ValueChanged="OnToolbarOpacityChanged" />
                                        <TextBlock x:Name="ToolbarOpacityValue"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource Settings.SubtleForeground}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 动作 ===================== -->
                        <Grid x:Name="ActionsPage"
                              Visibility="Collapsed"
                              Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="240" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource Settings.PageTitle}" Text="动作" />
                                    <TextBlock Style="{StaticResource Settings.PageDescription}"
                                               Text="选中文字后浮窗里显示的按钮。可拖拽调整顺序，开关右侧切换是否启用。"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Right">
                                    <ui:Button Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Add24}"
                                               Content="添加内置动作"
                                               Margin="0,0,6,0"
                                               Click="OnAddBuiltInAction" />
                                    <ui:Button Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Link24}"
                                               Content="添加 URL"
                                               Margin="0,0,6,0"
                                               Click="OnAddUrlAction" />
                                    <ui:Button Appearance="Primary"
                                               Icon="{ui:SymbolIcon Sparkle24}"
                                               Content="添加 AI 动作"
                                               Click="OnAddAiPromptAction" />
                                </StackPanel>
                            </Grid>

                            <!-- 模板速搭：从内置 Prompt 模板一键创建 ai 动作 -->
                            <Border Grid.Row="1" Style="{StaticResource Settings.SubCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}"
                                               Text="从内置 AI 模板快速添加："
                                               Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding BuiltinPromptTemplates}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Tag="{Binding}"
                                                        Click="OnAddFromTemplate"
                                                        Margin="0,0,6,6"
                                                        Padding="10,4"
                                                        Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                        BorderBrush="{DynamicResource Settings.Stroke}"
                                                        BorderThickness="1"
                                                        Foreground="{DynamicResource Settings.SubtleForeground}"
                                                        FontSize="12"
                                                        ToolTip="{Binding Description}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="11"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="＋" Margin="0,0,4,0" Opacity="0.7" />
                                                                    <TextBlock Text="{Binding Title}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Margin="0,8,0,0"
                                          CanContentScroll="False">
                                <ItemsControl x:Name="ActionsList"
                                              ItemsSource="{Binding ActionItems}"
                                              ItemTemplate="{StaticResource ActionItemTemplate}"
                                              AllowDrop="True"
                                              PreviewMouseLeftButtonDown="OnActionDragStart"
                                              MouseMove="OnActionMouseMove"
                                              Drop="OnActionDrop" />
                            </ScrollViewer>
                        </Grid>

                        <!-- ===================== 进程过滤 ===================== -->
                        <StackPanel x:Name="ProcessesPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="进程过滤" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="按前台进程过滤是否弹出工具栏：黑名单 = 列出的进程不弹；白名单 = 仅列出的进程弹" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,12">
                                        <RadioButton x:Name="BlacklistRadio" Content="黑名单" Margin="0,0,16,0" />
                                        <RadioButton x:Name="WhitelistRadio" Content="白名单" />
                                    </WrapPanel>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0" x:Name="ProcessNameBox"
                                                    PlaceholderText="例如 chrome.exe" />
                                        <ui:Button Grid.Column="1" Appearance="Primary" Content="添加 / 更新" Margin="8,0,0,0" Click="OnAddOrUpdateProcess" />
                                        <ui:Button Grid.Column="2" Appearance="Secondary" Content="删除" Margin="8,0,0,0" Click="OnRemoveProcess" />
                                        <ui:Button Grid.Column="3" Appearance="Transparent" Icon="{ui:SymbolIcon ArrowClockwise24}" Content="刷新最近" Margin="8,0,0,0" Click="OnRefreshRecentProcesses" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="过滤名单"
                                                       Style="{StaticResource Settings.FieldLabel}"
                                                       Margin="0,0,0,6" />
                                            <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource Settings.Radius.Sm}">
                                                <ListBox x:Name="ProcessList"
                                                         ItemsSource="{Binding ProcessFilters}"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         SelectionChanged="OnProcessSelected"
                                                         MinHeight="340" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="最近活动窗口"
                                                       Style="{StaticResource Settings.FieldLabel}"
                                                       Margin="0,0,0,6" />
                                            <Border BorderBrush="{DynamicResource Settings.Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource Settings.Radius.Sm}">
                                                <ListBox x:Name="RecentProcessList"
                                                         DisplayMemberPath="Display"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         SelectionChanged="OnRecentProcessPicked"
                                                         MinHeight="340" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 搜索引擎 ===================== -->
                        <StackPanel x:Name="SearchPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="搜索引擎" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="工具栏「搜索」按钮使用的引擎；URL 中 {q} 会被替换为选中文本的 UrlEncode 结果" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="预设引擎" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,18">
                                        <RadioButton x:Name="SearchGoogle" GroupName="SearchEngine" Content="Google" Margin="0,0,16,0" Click="OnSearchPresetChanged" />
                                        <RadioButton x:Name="SearchBing" GroupName="SearchEngine" Content="Bing" Margin="0,0,16,0" Click="OnSearchPresetChanged" />
                                        <RadioButton x:Name="SearchBaidu" GroupName="SearchEngine" Content="百度" Margin="0,0,16,0" Click="OnSearchPresetChanged" />
                                        <RadioButton x:Name="SearchCustom" GroupName="SearchEngine" Content="自定义" />
                                    </WrapPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="名称" />
                                        <ui:TextBox Grid.Column="1" x:Name="SearchEngineName" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="URL 模板" />
                                        <ui:TextBox Grid.Column="1" x:Name="SearchUrlTemplate" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 快捷键 ===================== -->
                        <StackPanel x:Name="HotkeysPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="快捷键" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="全局快捷键。格式：Ctrl+Alt+P，支持 Ctrl / Alt / Shift / Win 修饰键" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="280" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="暂停 / 恢复" />
                                        <ui:TextBox Grid.Column="1" x:Name="PauseHotKeyBox" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="280" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="唤起工具栏" />
                                        <ui:TextBox Grid.Column="1" x:Name="ToolbarHotKeyBox" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== AI ===================== -->
                        <StackPanel x:Name="AIPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="AI" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="选择模型服务并启用 AI 文本动作。选中文本会发送到当前配置的服务商。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <ui:ToggleSwitch x:Name="AiEnabledBox"
                                                     Content="启用 AI 动作入口" />

                                    <Grid Margin="0,16,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="Provider" />
                                        <ComboBox Grid.Column="1"
                                                  x:Name="AiProviderBox"
                                                  SelectionChanged="OnAiProviderChanged" />
                                        <TextBlock Grid.Column="2"
                                                   x:Name="AiProviderDescription"
                                                   Style="{StaticResource Settings.HintText}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="Base URL" />
                                        <ui:TextBox Grid.Column="1" x:Name="AiBaseUrlBox" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="Model" />
                                        <ui:TextBox Grid.Column="1" x:Name="AiModelBox" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="API Key" />
                                        <StackPanel Grid.Column="1">
                                            <PasswordBox x:Name="AiApiKeyBox" />
                                            <TextBlock x:Name="AiKeyStatus"
                                                       Style="{StaticResource Settings.HintText}"
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="超时 (秒)" />
                                        <ui:NumberBox Grid.Column="1"
                                                      x:Name="AiTimeoutBox"
                                                      Minimum="5"
                                                      Maximum="180"
                                                      SmallChange="5"
                                                      LargeChange="15" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource Settings.FieldLabel}" Text="默认输出语言" />
                                        <ui:TextBox Grid.Column="4" x:Name="AiDefaultLanguageBox" />
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="思考模式" />
                                        <ComboBox Grid.Column="1"
                                                  x:Name="AiThinkingModeBox" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource Settings.HintText}"
                                                   Text="自动保留服务商默认；快速降低延迟；深度优先推理质量。"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="单次最大输出 tokens" />
                                        <ui:NumberBox Grid.Column="1"
                                                      x:Name="AiMaxOutputTokensBox"
                                                      Minimum="0"
                                                      Maximum="262144"
                                                      SmallChange="512"
                                                      LargeChange="4096" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource Settings.HintText}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   Text="0=自动（快速 4K / 自动 16K / 深度 32K）。思考模型 reasoning 与正文共用此额度，过低会导致只输出思考过程。" />
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <ui:Button Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon PlugConnected24}"
                                                   Content="测试连接"
                                                   Click="OnAiTestConnection" />
                                    </StackPanel>

                                    <ui:InfoBar x:Name="AiTestInfo"
                                                Title="连接状态"
                                                Message=""
                                                Severity="Informational"
                                                IsClosable="False"
                                                IsOpen="False"
                                                Margin="0,12,0,0" />

                                    <ui:InfoBar Title="隐私提示"
                                                Message="启用后，AI 动作会把选中的文本发送到当前 Provider。API Key 将使用 Windows 当前用户加密保存。"
                                                Severity="Informational"
                                                IsClosable="False"
                                                IsOpen="True"
                                                Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== Prompt 模板 ===================== -->
                        <StackPanel x:Name="TemplatesPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="Prompt 模板" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="内置的高质量 Prompt 模板。点击右侧按钮即可一键提升为浮窗动作。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="内置模板" />
                                    <ItemsControl ItemsSource="{Binding BuiltinPromptTemplates}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                        BorderBrush="{DynamicResource Settings.Stroke}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource Settings.Radius.Md}"
                                                        Padding="14"
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource Settings.Foreground}" />
                                                                <Border Margin="8,0,0,0"
                                                                        Background="{DynamicResource Settings.AccentSoft}"
                                                                        CornerRadius="8"
                                                                        Padding="6,1"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding OutputMode}"
                                                                               FontSize="10.5"
                                                                               Foreground="{DynamicResource Settings.Accent}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}"
                                                                       Margin="0,4,0,4"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource Settings.SubtleForeground}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Prompt}"
                                                                       FontSize="11.5"
                                                                       Foreground="{DynamicResource Settings.Muted}"
                                                                       TextWrapping="Wrap"
                                                                       MaxHeight="60"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <ui:Button Grid.Column="1"
                                                                   VerticalAlignment="Top"
                                                                   Appearance="Primary"
                                                                   Icon="{ui:SymbolIcon Add24}"
                                                                   Content="加为动作"
                                                                   Tag="{Binding}"
                                                                   Click="OnAddFromTemplate" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 对话历史 ===================== -->
                        <StackPanel x:Name="HistoryPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="对话历史" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="最近的 AI 对话。点击条目可重新打开窗口继续追问。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0"
                                                    x:Name="HistorySearchBox"
                                                    PlaceholderText="搜索标题 / 引用文本 / 消息正文"
                                                    Icon="{ui:SymbolIcon Search24}"
                                                    TextChanged="OnHistorySearchChanged" />
                                        <ui:Button Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                                   Content="刷新"
                                                   Click="OnHistoryRefresh" />
                                    </Grid>
                                    <ListBox x:Name="HistoryListBox"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MaxHeight="420"
                                             MouseDoubleClick="OnHistoryDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource Settings.Foreground}" />
                                                        <TextBlock Text="{Binding MetaText}"
                                                                   FontSize="11.5"
                                                                   Foreground="{DynamicResource Settings.Muted}"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1"
                                                               Appearance="Transparent"
                                                               Icon="{ui:SymbolIcon Delete24}"
                                                               Tag="{Binding Id}"
                                                               Click="OnHistoryDeleteClicked"
                                                               Foreground="{DynamicResource Settings.Danger}"
                                                               ToolTip="删除此对话" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 用量 ===================== -->
                        <StackPanel x:Name="UsagePage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="AI 用量" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="每次 AI 调用都会按日聚合到本地数据库，不上传外部服务。" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="累计" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="UsageTotalCalls" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="次调用" FontSize="11.5"
                                                       Foreground="{DynamicResource Settings.Muted}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="UsageTotalPrompt" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="提示 token" FontSize="11.5"
                                                       Foreground="{DynamicResource Settings.Muted}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock x:Name="UsageTotalCompletion" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="补全 token" FontSize="11.5"
                                                       Foreground="{DynamicResource Settings.Muted}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock x:Name="UsageTotalElapsed" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="累计耗时" FontSize="11.5"
                                                       Foreground="{DynamicResource Settings.Muted}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Settings.SectionTitle}" Text="近 30 天每日明细" />
                                    <ListBox x:Name="UsageList"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MaxHeight="420">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding DateLabel}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Settings.Foreground}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding CallsLabel}"
                                                               Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding PromptLabel}"
                                                               Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding CompletionLabel}"
                                                               Foreground="{DynamicResource Settings.SubtleForeground}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ===================== 关于 ===================== -->
                        <StackPanel x:Name="AboutPage" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource Settings.PageTitle}" Text="关于" />
                            <TextBlock Style="{StaticResource Settings.PageDescription}"
                                       Text="应用状态、日志记录与本地目录" />

                            <Border Style="{StaticResource Settings.Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="56" Height="56"
                                                Background="{DynamicResource Settings.Card.SubtleBackground}"
                                                BorderBrush="{DynamicResource Settings.Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Settings.Radius.Md}"
                                                Margin="0,0,16,0">
                                            <Image Source="pack://application:,,,/Assets/AppIcon.ico"
                                                   Width="40"
                                                   Height="40"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Stretch="Uniform" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="ClipAura" FontSize="22" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Settings.Foreground}" />
                                            <TextBlock Text="Windows 选区动作工具"
                                                       Foreground="{DynamicResource Settings.SubtleForeground}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="UIA 状态" />
                                        <TextBlock x:Name="AboutUiaStatusText"
                                                   Grid.Row="0" Grid.Column="1"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="进程权限" />
                                        <TextBlock x:Name="AboutPrivilegeStatusText"
                                                   Grid.Row="1" Grid.Column="1"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="日志等级" />
                                        <ComboBox x:Name="LogLevelBox"
                                                  Grid.Column="1"
                                                  Width="180"
                                                  HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="日志目录" />
                                        <TextBlock x:Name="LogDirectoryPathText"
                                                   Grid.Column="1"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <ui:Button Grid.Column="2"
                                                   Margin="12,0,0,0"
                                                   Appearance="Secondary"
                                                   Content="打开"
                                                   Click="OnOpenLogDirectory" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource Settings.FieldLabel}" Text="配置目录" />
                                        <TextBlock x:Name="ConfigDirectoryPathText"
                                                   Grid.Column="1"
                                                   Foreground="{DynamicResource Settings.Foreground}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <ui:Button Grid.Column="2"
                                                   Margin="12,0,0,0"
                                                   Appearance="Secondary"
                                                   Content="打开"
                                                   Click="OnOpenConfigDirectory" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- 底部 sticky 操作栏 -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Settings.Card.Background}"
                        BorderBrush="{DynamicResource Settings.Stroke}"
                        BorderThickness="0,1,0,0"
                        Padding="36,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button x:Name="CancelBtn"
                                   Appearance="Secondary"
                                   Content="取消"
                                   Width="100"
                                   Margin="0,0,10,0"
                                   Click="OnCancel" />
                        <ui:Button x:Name="OkBtn"
                                   Appearance="Primary"
                                   Content="保存"
                                   Width="100"
                                   Click="OnSave" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
