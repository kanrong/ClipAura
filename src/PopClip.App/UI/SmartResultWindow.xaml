<ui:FluentWindow x:Class="PopClip.App.UI.SmartResultWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="ClipAura 结果"
                 Width="720"
                 Height="540"
                 MinWidth="480"
                 MinHeight="320"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Background="{DynamicResource Settings.Window.Background}"
                 Foreground="{DynamicResource Settings.Foreground}"
                 FontFamily="{DynamicResource Settings.FontFamily}">
    <Grid Background="{DynamicResource Settings.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     x:Name="TitleBar"
                     Title="结果"
                     Style="{StaticResource Settings.CompactTitleBar}"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Document24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border Grid.Row="1"
                Margin="14,8,14,4"
                Background="{DynamicResource Settings.Card.SubtleBackground}"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="1"
                CornerRadius="{StaticResource Settings.Radius.Sm}"
                Padding="10,8">
            <StackPanel>
                <TextBlock x:Name="MetaText"
                           FontSize="11.5"
                           Foreground="{DynamicResource Settings.SubtleForeground}" />
                <TextBlock x:Name="ReferenceText"
                           FontSize="12"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource Settings.Muted}"
                           TextWrapping="Wrap"
                           MaxHeight="80"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      Padding="14,4,14,4"
                      VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="ResultText"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{DynamicResource Settings.Foreground}"
                     FontFamily="Consolas, 'Cascadia Mono', 'Microsoft YaHei', Consolas"
                     FontSize="13"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Disabled"
                     HorizontalScrollBarVisibility="Disabled" />
        </ScrollViewer>

        <Border Grid.Row="3"
                Margin="14,4,14,12"
                BorderBrush="{DynamicResource Settings.Stroke}"
                BorderThickness="0,1,0,0"
                Padding="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="CopyButton"
                           Content="复制结果"
                           Appearance="Primary"
                           Click="OnCopyClicked" />
                <ui:Button Content="关闭"
                           Margin="8,0,0,0"
                           Click="OnCloseClicked" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
