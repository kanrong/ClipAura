<Window x:Class="PopClip.App.UI.ToolbarToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource ToolbarFontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <!-- "复制" 小按钮：与浮窗内 ToastCopyButton 视觉一致 -->
        <Style x:Key="ToastCopyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarForeground}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToolbarHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 外层 8px Margin 让 DropShadowEffect 不被透明窗口边界裁切；
         与浮窗一样三层结构（阴影底板 → 主面板 → 描边层）。
         MaxWidth=420 让多行 toast 在屏幕上不至于撑得太宽（OCR / 智能动作的多行结果常见场景） -->
    <Grid Margin="8" SnapsToDevicePixels="True" MaxWidth="420">
        <Border Background="{DynamicResource ToolbarToastBackground}"
                CornerRadius="6"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000"
                                  Direction="270"
                                  BlurRadius="8"
                                  ShadowDepth="2"
                                  Opacity="0.42"
                                  RenderingBias="Performance" />
            </Border.Effect>
        </Border>

        <Border x:Name="ToastBorder"
                Background="{DynamicResource ToolbarToastBackground}"
                CornerRadius="6"
                Padding="12,7"
                SnapsToDevicePixels="True">
            <DockPanel LastChildFill="True">
                <Button x:Name="ToastCopyButton"
                        Style="{StaticResource ToastCopyButtonStyle}"
                        Content="复制"
                        DockPanel.Dock="Right"
                        Margin="10,0,0,0"
                        Padding="6,2"
                        Click="OnCopyClicked"
                        Visibility="Collapsed" />
                <!-- ScrollViewer 让超长内容也能在 toast 里查看，最高 180 DIP；
                     单行内容时 TextBlock 仍按内容自适应高度，不会被 ScrollViewer 强行撑高 -->
                <ScrollViewer MaxHeight="180"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="ToastText"
                               Foreground="{DynamicResource ToolbarForeground}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ToolbarBorder}"
                BorderThickness="1"
                CornerRadius="6"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True" />
    </Grid>
</Window>
